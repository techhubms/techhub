@* ============================================================================
   Sub-Navigation Component
   
   Horizontal navigation below page header showing collections and custom pages.
   Used across section pages to provide secondary navigation.
   On the homepage, shows RSS/Newsletter action buttons and a mobile section dropdown.
   
   Usage:
     Section page:  <SubNav Section="@sectionData" RssFeedUrl="/ai/feed.xml" ShowNewsletter="true" />
     Homepage:      <SubNav Sections="@allSections" RssFeedUrl="/all/feed.xml" ShowNewsletter="true" />
     About page:    <SubNav Sections="@allSections" HideStats="true" ShowDiscord="true" />
     Newsletter:    <SubNav Sections="@allSections" ShowHomepageButton="true" />
   ============================================================================ *@

@using TechHub.Core.Models
@using TechHub.Web.Services
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject HomepageStatsState HomepageStats
@implements IDisposable

@if (Section != null)
{
    <nav class="sub-nav" aria-label="@Section.Title navigation">
        @* Desktop: horizontal button bar *@
        <div class="sub-nav-wrapper">
            <a href="/@Section.Name/all" class="btn-subnav btn-subnav-custom @(IsBrowseActive ? "active" : "")"
               @onclick="@(() => OnSubNavClick($"/{Section.Name}/all"))" @onclick:preventDefault="@IsCurrentPage($"/{Section.Name}/all")">
                Browse
            </a>

            @if (!Section.HideCollectionPages)
            {
                @foreach (var collection in RegularCollections)
                {
                    var url = $"/{Section.Name}/{collection.Name}";
                    <a href="@url" class="btn-subnav @(IsActive(url) ? "active" : "")"
                       @onclick="@(() => OnSubNavClick(url))" @onclick:preventDefault="@IsCurrentPage(url)">
                        @collection.Title
                    </a>
                }
            }

            @foreach (var customPage in CustomPages)
            {
                <a href="@customPage.Url" class="btn-subnav btn-subnav-custom @(IsActive(customPage.Url) ? "active" : "")"
                   @onclick="@(() => OnSubNavClick(customPage.Url))" @onclick:preventDefault="@IsCurrentPage(customPage.Url)">
                    @customPage.Title
                </a>
            }
        </div>

        @* Mobile: dropdown showing active page *@
        <div class="sub-nav-mobile">
            <button class="sub-nav-dropdown-toggle" @onclick="ToggleDropdown" aria-expanded="@(dropdownOpen ? "true" : "false")">
                <span>@ActiveLabel</span>
                <span class="sub-nav-chevron @(dropdownOpen ? "expanded" : "")"></span>
            </button>
            @if (dropdownOpen)
            {
                <div class="sub-nav-dropdown-menu">
                    <a href="/@Section.Name/all" class="sub-nav-dropdown-item sub-nav-dropdown-custom @(IsBrowseActive ? "active" : "")"
                       @onclick="@(() => OnSubNavDropdownClick($"/{Section.Name}/all"))" @onclick:preventDefault="@IsCurrentPage($"/{Section.Name}/all")">
                        Browse
                    </a>
                    @if (!Section.HideCollectionPages)
                    {
                        @foreach (var collection in RegularCollections)
                        {
                            var url = $"/{Section.Name}/{collection.Name}";
                            <a href="@url" class="sub-nav-dropdown-item @(IsActive(url) ? "active" : "")"
                               @onclick="@(() => OnSubNavDropdownClick(url))" @onclick:preventDefault="@IsCurrentPage(url)">
                                @collection.Title
                            </a>
                        }
                    }
                    @foreach (var customPage in CustomPages)
                    {
                        <a href="@customPage.Url" class="sub-nav-dropdown-item sub-nav-dropdown-custom @(IsActive(customPage.Url) ? "active" : "")"
                           @onclick="@(() => OnSubNavDropdownClick(customPage.Url))" @onclick:preventDefault="@IsCurrentPage(customPage.Url)">
                            @customPage.Title
                        </a>
                    }
                </div>
            }
        </div>
    </nav>
}
else if (Sections != null && Sections.Any())
{
    @* Homepage SubNav: stat buttons + Newsletter; visible on desktop and mobile (no dropdown) *@
    <nav class="sub-nav sub-nav-homepage-visible" aria-label="Site navigation">
        <div class="sub-nav-wrapper">
            @if (!HideStats && HomepageStats.TotalCount.HasValue)
            {
                @if (HomepageStats.RecentCount is > 0)
                {
                    <a href="/all?from=@HomepageStats.WeekAgoDate" class="btn-subnav btn-subnav-action btn-subnav-stat-new" aria-label="@HomepageStats.RecentCount new items this week">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 0.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14c0 4.42 3.58 8 8 8s8-3.58 8-8C20 8.61 17.41 3.8 13.5.67zM11.71 19c-1.78 0-3.22-1.4-3.22-3.14 0-1.62 1.05-2.76 2.81-3.12 1.77-.36 3.6-1.21 4.62-2.58.39 1.29.59 2.65.59 4.04 0 2.65-2.15 4.8-4.8 4.8z"/></svg><span>@HomepageStats.RecentCount<span class="stat-chip-new-label"> new this week</span></span>
                    </a>
                }
                <a href="/all" class="btn-subnav btn-subnav-action btn-subnav-stat-total" aria-label="@HomepageStats.TotalCount items total">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.99 18.54l-7.37-5.73L3 14.07l9 7 9-7-1.63-1.27-7.38 5.74zM12 16l7.36-5.73L21 9l-9-7-9 7 1.63 1.27L12 16z"/></svg><span>@HomepageStats.TotalCount.Value.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)<span class="stat-chip-total-label"> items total</span></span>
                </a>
            }
            @if (ShowNewsletter)
            {
                <a href="/newsletter/subscribe" class="btn-subnav btn-subnav-action btn-subnav-newsletter" aria-label="Subscribe to newsletter">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" /></svg>
                    Newsletter
                </a>
            }
            @if (ShowDiscord)
            {
                <a href="https://discord.gg/cURHV9TvFS" target="_blank" rel="noopener noreferrer" class="btn-subnav btn-subnav-action btn-subnav-discord" aria-label="Join our Discord server">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.1 18.08.114 18.1.132 18.112a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
                    Find us on GitHub Community Discord
                </a>
            }
            @if (ShowHomepageButton)
            {
                <a href="/" class="btn-subnav btn-subnav-action btn-subnav-newsletter">
                    Homepage
                </a>
            }
        </div>
    </nav>
}
@* Empty SubNav: render nothing so it collapses *@

@code {
    [Parameter]
    public Section? Section { get; set; }

    /// <summary>
    /// List of all sections. Used on the homepage to show section links in the subnav.
    /// </summary>
    [Parameter]
    public IEnumerable<Section>? Sections { get; set; }

    /// <summary>
    /// Optional RSS feed URL. When provided, renders an RSS button in the action area.
    /// </summary>
    [Parameter]
    public string? RssFeedUrl { get; set; }

    /// <summary>
    /// When true, renders a Newsletter subscribe button in the action area.
    /// </summary>
    [Parameter]
    public bool ShowNewsletter { get; set; }

    /// <summary>
    /// When true, hides the statistics box. Used on the About page where stats are not relevant.
    /// </summary>
    [Parameter]
    public bool HideStats { get; set; }

    /// <summary>
    /// When true, renders a Discord button. Used on the About page.
    /// </summary>
    [Parameter]
    public bool ShowDiscord { get; set; }

    /// <summary>
    /// When true, renders a Homepage button. Used on the Newsletter page for quick back-navigation.
    /// </summary>
    [Parameter]
    public bool ShowHomepageButton { get; set; }

    private bool HasActions => !string.IsNullOrEmpty(RssFeedUrl) || ShowNewsletter;

    private bool dropdownOpen;

    private IEnumerable<Collection> RegularCollections =>
    Section?.Collections?.Where(c => !c.IsCustom) ?? Enumerable.Empty<Collection>();

    private IEnumerable<Collection> CustomPages =>
    Section?.Collections?
        .Where(c => c.IsCustom)
        .OrderBy(c => c.Order)
        .ThenBy(c => c.Title) ?? Enumerable.Empty<Collection>();

    /// <summary>
    /// Whether the "Browse" button should be active. When HideCollectionPages is true,
    /// Browse is also active when viewing any regular collection route (e.g., /github-copilot/videos).
    /// </summary>
    private bool IsBrowseActive
    {
        get
        {
            if (Section == null) return false;
            if (IsActive($"/{Section.Name}/all")) return true;

            // When collection pages are hidden, Browse is also active for regular collection routes
            if (Section.HideCollectionPages)
            {
                foreach (var collection in RegularCollections)
                {
                    var url = $"/{Section.Name}/{collection.Name}";
                    if (IsActive(url)) return true;
                }
            }

            return false;
        }
    }

    private string ActiveLabel
    {
        get
        {
            if (Section == null) return "";

            // When collection pages are hidden, show "Browse" for any regular collection route
            if (!Section.HideCollectionPages)
            {
                foreach (var collection in RegularCollections)
                {
                    var url = $"/{Section.Name}/{collection.Name}";
                    if (IsActive(url)) return collection.Title;
                }
            }

            foreach (var customPage in CustomPages)
            {
                if (IsActive(customPage.Url)) return customPage.Title;
            }

            return "Browse";
        }
    }

    private void ToggleDropdown() => dropdownOpen = !dropdownOpen;

    private void CloseDropdown() => dropdownOpen = false;

    /// <summary>
    /// When clicking the already-active subnav item, scroll to top instead of staying in place.
    /// Also clears any URL hash so F5 doesn't jump back down.
    /// </summary>
    private async Task OnSubNavClick(string url)
    {
        if (IsCurrentPage(url))
        {
            await ScrollToTopAndClearHash();
        }
    }

    /// <summary>
    /// Same as OnSubNavClick but also closes the mobile dropdown.
    /// </summary>
    private async Task OnSubNavDropdownClick(string url)
    {
        CloseDropdown();
        if (IsCurrentPage(url))
        {
            await ScrollToTopAndClearHash();
        }
    }

    private async Task ScrollToTopAndClearHash()
    {
        // Scroll to top and remove hash from URL so refreshing doesn't jump back down.
        // Uses a single JS call to handle both operations atomically.
        // Must check window.location.hash in JS because Blazor's NavigationManager.Uri
        // may not include the fragment (hash fragments are client-side only in Blazor Server).
        await JS.InvokeVoidAsync("TechHub.scrollToTopAndClearHash");
    }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        HomepageStats.OnChanged += OnHomepageStatsChanged;
    }

    private void OnHomepageStatsChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        dropdownOpen = false;
        // Re-render to update active state when the URL changes
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        HomepageStats.OnChanged -= OnHomepageStatsChanged;
    }

    /// <summary>
    /// Determines if the given URL should be visually highlighted in the subnav.
    /// Matches both exact pages and content detail pages under a collection.
    /// Used for CSS active class only.
    /// </summary>
    private bool IsActive(string url)
    {
        var currentUri = new Uri(Navigation.Uri);
        var currentPath = currentUri.AbsolutePath.TrimEnd('/');
        var targetPath = url.TrimEnd('/');

        // For section root (e.g., /ai), also match /{sectionName}/all
        if (targetPath.EndsWith("/all", StringComparison.OrdinalIgnoreCase))
        {
            var sectionPath = targetPath[..^4]; // Remove "/all"
                                                // Match /ai/all or just /ai
            if (currentPath.Equals(targetPath, StringComparison.OrdinalIgnoreCase) ||
            currentPath.Equals(sectionPath, StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }
        }

        // For collections and custom pages - exact match or content detail pages under them
        if (currentPath.Equals(targetPath, StringComparison.OrdinalIgnoreCase) ||
        currentPath.StartsWith(targetPath + "/", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return false;
    }

    /// <summary>
    /// Determines if the user is on the exact page matching the URL.
    /// Used for preventDefault and scroll-to-top behavior — only triggers
    /// when already on the target page, not on child/detail pages.
    /// </summary>
    private bool IsCurrentPage(string url)
    {
        var currentUri = new Uri(Navigation.Uri);
        var currentPath = currentUri.AbsolutePath.TrimEnd('/');
        var targetPath = url.TrimEnd('/');

        // For section root (e.g., /ai), also match /{sectionName}/all
        if (targetPath.EndsWith("/all", StringComparison.OrdinalIgnoreCase))
        {
            var sectionPath = targetPath[..^4]; // Remove "/all"
            return currentPath.Equals(targetPath, StringComparison.OrdinalIgnoreCase) ||
                   currentPath.Equals(sectionPath, StringComparison.OrdinalIgnoreCase);
        }

        return currentPath.Equals(targetPath, StringComparison.OrdinalIgnoreCase);
    }
}