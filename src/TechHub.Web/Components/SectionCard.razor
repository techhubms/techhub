@using TechHub.Core.Models
@inject NavigationManager Navigation

<div class="section-card-container">
    <a href="@Section.Url" class="section-card" aria-label="View @Section.Title section">
        <div class="section-card-header section-bg-@Section.Name" role="img"
            aria-label="@Section.Title section background">
            <div class="section-overlay">
                <h2>@Section.Title</h2>
            </div>
        </div>
        <div class="section-body">
            <p class="section-description">@Section.Description</p>
        </div>
    </a>
    @if (Section.Collections.Any())
    {
        <nav class="section-collections" aria-label="@Section.Title collections">
            @* Show all regular collections *@
            @foreach (var collection in RegularCollections)
            {
                <a href="@collection.Url" class="badge-purple" aria-label="View @collection.Title collection">
                    @collection.Title
                </a>
            }
            
            @* Show first 2 custom pages if they exist *@
            @if (CustomPages.Any())
            {
                @foreach (var customPage in CustomPages.Take(DefaultVisibleCustomPages))
                {
                    <a href="@customPage.Url" class="badge-custom"
                        aria-label="View @customPage.Title custom page">
                        @customPage.Title
                    </a>
                }
                
                @* Show "+X more" button if there are additional custom pages beyond the default visible *@
                @if (CustomPages.Count > DefaultVisibleCustomPages)
                {
                    var expandId = $"custom-pages-{Section.Name}";
                    var remainingCount = CustomPages.Count - DefaultVisibleCustomPages;
                    var isExpanded = _expandedSections.Contains(expandId);
                    
                    @if (!isExpanded)
                    {
                        <button type="button" 
                                class="badge-grey badge-expandable" 
                                data-expand-target="@expandId"
                                data-initialized="blazor"
                                @onclick="() => ExpandSection(expandId)"
                                @onclick:stopPropagation="true"
                                @onclick:preventDefault="true"
                                aria-expanded="false"
                                aria-label="Show @remainingCount more custom pages">
                            +@remainingCount more
                        </button>
                    }
                    
                    @* Hidden custom pages - revealed when button clicked *@
                    <span id="@expandId" class="custom-pages-expanded" hidden="@(!isExpanded)">
                        @foreach (var customPage in CustomPages.Skip(DefaultVisibleCustomPages))
                        {
                            <a href="@customPage.Url" class="badge-custom"
                                aria-label="View @customPage.Title custom page">
                                @customPage.Title
                            </a>
                        }
                    </span>
                }
            }
        </nav>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public Section Section { get; set; } = null!;
    
    private IEnumerable<Collection> RegularCollections => 
        Section.Collections.Where(c => !c.IsCustom);
    
    private const int DefaultVisibleCustomPages = 2;
    
    private IReadOnlyList<Collection> CustomPages => 
        Section.Collections
            .Where(c => c.IsCustom)
            .OrderBy(c => c.Order)
            .ThenBy(c => c.Title)
            .ToList();
    
    private readonly HashSet<string> _expandedSections = new();
    private string? _previousSectionName;
    
    protected override void OnParametersSet()
    {
        // Reset expansion state when Section changes (prevents state bleed
        // when Blazor reuses this component instance for a different Section).
        if (_previousSectionName != Section.Name)
        {
            _expandedSections.Clear();
            _previousSectionName = Section.Name;
        }
    }
    
    private void ExpandSection(string sectionId)
    {
        _expandedSections.Add(sectionId);
    }
}
