@using TechHub.Core.Models
@using TechHub.Web.Services
@inject SectionCache SectionCache

@* 
   Header Component - Complete site header structure
   Rendered by MainLayout.razor (not by individual pages).
   
   Usage (via MainLayout):
     With section name (section/collection/content pages):
       <Header SectionName="ai" RssFeedUrl="/ai/feed.xml" ShowNewsletter="true" />
     
     With custom banner (home, about, not-found, error pages):
       <Header CustomBannerTitle="Tech Hub" CustomBannerDescription="..." RssFeedUrl="/all/feed.xml" ShowNewsletter="true" />
       <Header CustomBannerTitle="About Us" CustomBannerDescription="..." HideStats="true" ShowDiscord="true" />
       <Header CustomBannerTitle="Newsletter" CustomBannerDescription="..." />
     
     Without section/banner (fallback):
       <Header />
*@

<header>
    <NavHeader />

    @if (!string.IsNullOrEmpty(SectionName))
    {
        var sectionData = SectionCache.GetSectionByName(SectionName);
        if (sectionData != null)
        {
            <SectionBanner Section="@sectionData" RssFeedUrl="@RssFeedUrl" />
            <SubNav Section="@sectionData" RssFeedUrl="@RssFeedUrl" ShowNewsletter="@ShowNewsletter" />
        }
        else
        {
            <SubNav />
        }
    }
    else if (!string.IsNullOrEmpty(CustomBannerTitle))
    {
        <SectionBanner Title="@CustomBannerTitle" Description="@CustomBannerDescription" RssFeedUrl="@RssFeedUrl" IsHomepage="@IsHomepage" />
        @if (!HideSubNav)
        {
            <SubNav Sections="@SectionCache.Sections" RssFeedUrl="@RssFeedUrl" ShowNewsletter="@ShowNewsletter" HideStats="@HideStats" ShowDiscord="@ShowDiscord" ShowHomeButton="@ShowHomeButton" />
        }
    }
    else if (ChildContent != null)
    {
        @ChildContent
        <SubNav Sections="@SectionCache.Sections" RssFeedUrl="@RssFeedUrl" ShowNewsletter="@ShowNewsletter" HideStats="@HideStats" ShowDiscord="@ShowDiscord" ShowHomeButton="@ShowHomeButton" />
    }
    else
    {
        <SubNav Sections="@SectionCache.Sections" RssFeedUrl="@RssFeedUrl" ShowNewsletter="@ShowNewsletter" HideStats="@HideStats" ShowDiscord="@ShowDiscord" ShowHomeButton="@ShowHomeButton" />
    }
</header>

@code {
    [Parameter]
    public string? SectionName { get; set; }

    /// <summary>
    /// Optional RSS feed URL. Passed through to SectionBanner and SubNav.
    /// </summary>
    [Parameter]
    public string? RssFeedUrl { get; set; }

    /// <summary>
    /// When true, renders a Newsletter subscribe button in the SubNav action area.
    /// </summary>
    [Parameter]
    public bool ShowNewsletter { get; set; }

    /// <summary>
    /// When true, hides the statistics box in the SubNav. Used on pages where stats are not relevant (e.g. About).
    /// </summary>
    [Parameter]
    public bool HideStats { get; set; }

    /// <summary>
    /// When true, renders a Discord button in the SubNav. Used on the About page.
    /// </summary>
    [Parameter]
    public bool ShowDiscord { get; set; }

    /// <summary>
    /// When true, renders a "Home" button in the SubNav that is highlighted when on the homepage.
    /// </summary>
    [Parameter]
    public bool ShowHomeButton { get; set; }

    /// <summary>
    /// When true, renders the SectionBanner with homepage-specific styling and "Home" as the mobile title.
    /// </summary>
    [Parameter]
    public bool IsHomepage { get; set; }

    /// <summary>
    /// When true, hides the SubNav completely. Used on pages where navigation is not needed (e.g. Newsletter).
    /// </summary>
    [Parameter]
    public bool HideSubNav { get; set; }

    /// <summary>
    /// Optional custom banner title (used by MainLayout for special pages like Home, About, etc.).
    /// When set without SectionName, renders a SectionBanner with this title.
    /// </summary>
    [Parameter]
    public string? CustomBannerTitle { get; set; }

    /// <summary>
    /// Optional custom banner description (used with CustomBannerTitle).
    /// </summary>
    [Parameter]
    public string? CustomBannerDescription { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}