@page "/about"
@using TechHub.Web.Services
@inject BrandingService Branding

<PageTitle>About Us - @Branding.SiteName</PageTitle>

<SeoMetaTags
    Title="@($"About Us - {Branding.SiteName}")"
    Description="Meet the team behind Tech Hub — technology consultants passionate about GitHub Copilot, AI, Azure, .NET, and cloud-native development."
    ContentType="SeoMetaTags.SeoContentType.Website" />

<main class="page-without-sidebar">
    <section>
        @if (Branding.IsXebiaBranding)
        {
            <h1 id="skiptohere" class="page-h1">Xebia</h1>

            <div class="xebia-section">
                <p>
                    This website is brought to you by <a href="https://xebia.com/" target="_blank" rel="noopener noreferrer">Xebia</a>,
                    a global IT consultancy company that drives digital transformation through technology
                    and software engineering excellence. We are passionate about empowering teams with the
                    latest tools and practices to build better software, faster.
                </p>
            </div>

            <h2>Who are we</h2>
        }
        else
        {
            <h1 id="skiptohere" class="page-h1">Who are we</h1>
        }

        <div class="team-members">
            <div class="team-member">
                <img src="/images/about/reinier.jpg" alt="Reinier van Maanen" class="team-photo" />
                <h3>Reinier van Maanen</h3>
                <p class="team-role">Cloud Native Development Consultant</p>
                <p class="team-bio">
                    Reinier is a Cloud Native Development Consultant at Xebia Microsoft Services, specializing in Azure,
                    GitHub, and cloud-native solutions. He is passionate about helping organizations
                    transform their software development practices and modernize their applications.
                </p>
                <div class="team-links">
                    <a href="https://github.com/rvanmaanen" target="_blank" rel="noopener noreferrer">
                        <span class="icon">📘</span> GitHub
                    </a>
                    <a href="https://linkedin.com/in/reiniervanmaanen" target="_blank" rel="noopener noreferrer">
                        <span class="icon">💼</span> LinkedIn
                    </a>
                    <a href="https://r-vm.com/" target="_blank" rel="noopener noreferrer">
                        <span class="icon">✍️</span> Blog
                    </a>
                </div>
            </div>

            <div class="team-member">
                <img src="/images/about/rob.jpg" alt="Rob Bos" class="team-photo" />
                <h3>Rob Bos</h3>
                <p class="team-role">Principal DevOps Trainer</p>
                <p class="team-bio">
                    Rob is a Microsoft MVP, GitHub Star, and Principal Trainer focused on DevOps,
                    GitHub Actions, and team enablement. He empowers teams to work smarter with
                    GitHub tools, automating processes, improving security, and driving value delivery.
                </p>
                <div class="team-links">
                    <a href="https://github.com/rajbos" target="_blank" rel="noopener noreferrer">
                        <span class="icon">📘</span> GitHub
                    </a>
                    <a href="https://linkedin.com/in/bosrob" target="_blank" rel="noopener noreferrer">
                        <span class="icon">💼</span> LinkedIn
                    </a>
                    <a href="https://devopsjournal.io/" target="_blank" rel="noopener noreferrer">
                        <span class="icon">✍️</span> Blog
                    </a>
                </div>
            </div>

            <div class="team-member">
                <img src="/images/about/fokko.jpg" alt="Fokko Veegens" class="team-photo" />
                <h3>Fokko Veegens</h3>
                <p class="team-role">DevOps Consultant</p>
                <p class="team-bio">
                    Fokko is a DevOps Consultant specializing in Azure, GitHub, and modern software
                    development practices. He helps organizations optimize their development workflows
                    and adopt cloud-native technologies effectively.
                </p>
                <div class="team-links">
                    <a href="https://github.com/fokkoveegens" target="_blank" rel="noopener noreferrer">
                        <span class="icon">📘</span> GitHub
                    </a>
                    <a href="https://www.linkedin.com/in/fokkoveegens/" target="_blank" rel="noopener noreferrer">
                        <span class="icon">💼</span> LinkedIn
                    </a>
                    <a href="#" aria-hidden="true" style="visibility: hidden; pointer-events: none;">
                        <span class="icon">✍️</span> Blog
                    </a>
                </div>
            </div>
        </div>

        <h2>Discord</h2>

        <div class="discord-section">
            <p>
                We've started a Discord server where we and other GitHub Copilot experts are present
                and will try to help out if you run into any issues. Come join the conversation!
            </p>
            <a href="https://discord.gg/cURHV9TvFS" class="discord-link" target="_blank" rel="noopener noreferrer">
                Join our Discord server
            </a>
        </div>

        <h2>Why did we build this</h2>

        <div class="about-intro">
            <p>
                Because we know it's hard to stay up-to-date with the fast changing world of IT,
                here is a website where you'll find blogs, news, videos and more content about
                technology in the Microsoft space. Constantly updated and pre-screened to only
                provide useful content.
            </p>
        </div>
    </section>
</main>