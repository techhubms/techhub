@page "/{sectionName}"
@page "/{sectionName}/{collectionName}"
@using TechHub.Core.Models
@using TechHub.Web.Services

@inject SectionCache SectionCache
@inject NavigationManager Navigation

<PageTitle>@PageTitleText</PageTitle>

<SeoMetaTags
    Title="@PageTitleText"
    Description="@SeoDescription"
    ContentType="SeoMetaTags.SeoContentType.Collection"
    ArticleSection="@(section?.Title)"
    Breadcrumbs="@GetBreadcrumbs()"
    RssFeedUrl="@($"/{SectionName}/feed.xml")" />

<main class="page-with-sidebar">
    <aside class="sidebar">
        <SidebarToggle />
        <MobileSidebarToolbar @key="@ShowContentTypeFilter">
        @if (ShowContentTypeFilter)
        {
        <MobileSidebarPanel Label="Content" Icon="filter" HasActiveFilter="@HasActiveTypeFilter">
        <div class="sidebar-section">
            <h2 class="sidebar-h2">Content Type</h2>
            <div class="content-type-filter">
                @foreach (var collectionType in ContentTypeCollections)
                {
                    var isActive = IsContentTypeActive(collectionType.Name);
                    <button class="content-type-btn @(isActive ? "active" : "")"
                            @onclick="@(() => ToggleContentType(collectionType.Name))">
                        @collectionType.Title
                    </button>
                }
            </div>
        </div>
        </MobileSidebarPanel>
        }
        <MobileSidebarPanel Label="Search" Icon="search" HasActiveFilter="@(!string.IsNullOrWhiteSpace(searchQuery))">
        <SidebarSearch SearchQuery="@searchQuery" OnSearchQueryChanged="HandleSearchQueryChanged" />
        </MobileSidebarPanel>
        <MobileSidebarPanel Label="Date" Icon="calendar" HasActiveFilter="@(fromDate != null || toDate != null)">
        <DateRangeSlider FromDate="@fromDate" ToDate="@toDate"
            OnDateRangeChanged="HandleDateRangeChanged" />
        </MobileSidebarPanel>
        <MobileSidebarPanel Label="Tags" Icon="tags" HasActiveFilter="@(selectedTags.Count > 0)">
        <SidebarTagCloud SectionName="@SectionName" CollectionName="@EffectiveCollectionName"
            Title="Popular Tags" NavigationMode="TagCloudNavigationMode.Filter" SelectedTags="@selectedTags"
            FromDate="@fromDateString" ToDate="@toDateString"
            SearchQuery="@searchQuery"
            OnSelectionChanged="HandleTagSelectionChanged" />
        </MobileSidebarPanel>
        </MobileSidebarToolbar>
        <div class="sidebar-desktop-only">
        <SidebarRssLinks Links="@(new[] { new SidebarRssLinks.RssLink("RSS Feed", $"/{SectionName}/feed.xml") })" />
        </div>
    </aside>

    <section>
        <ContentItemsGrid SectionName="@SectionName" CollectionName="@EffectiveCollectionName" FilterTags="@selectedTags"
            SearchQuery="@searchQuery" FromDate="@fromDateString" ToDate="@toDateString"
            ContentTypes="@ActiveContentTypesParam"
            @key="@GridKey" />
    </section>
</main>

@code {
    [Parameter]
    public string SectionName { get; set; } = null!;

    [Parameter]
    public string? CollectionName { get; set; }

    [SupplyParameterFromQuery(Name = "tags")]
    public string? TagsParam { get; set; }

    [SupplyParameterFromQuery(Name = "search")]
    public string? SearchParam { get; set; }

    [SupplyParameterFromQuery(Name = "from")]
    public string? FromParam { get; set; }

    [SupplyParameterFromQuery(Name = "to")]
    public string? ToParam { get; set; }

    [SupplyParameterFromQuery(Name = "types")]
    public string? TypesParam { get; set; }

    private List<string> selectedTags = new();
    private string searchQuery = string.Empty;
    private TechHub.Core.Models.Section? section;
    private TechHub.Core.Models.Collection? collection;
    private DateOnly? fromDate;
    private DateOnly? toDate;
    private string? fromDateString;
    private string? toDateString;
    private string? _previousSectionName;
    private string? _previousCollectionName;
    private HashSet<string> activeContentTypes = new(StringComparer.OrdinalIgnoreCase);
    private bool IsAll => string.Equals(CollectionName, "all", StringComparison.OrdinalIgnoreCase);

    /// <summary>
    /// Whether to show the content-type filter in the sidebar.
    /// Shown on every Browse page (the /all route) that has at least one filterable (non-custom) collection.
    /// </summary>
    private bool ShowContentTypeFilter => IsAll && ContentTypeCollections.Count > 0;

    /// <summary>
    /// Whether any content type filter is active (not all types selected).
    /// </summary>
    private bool HasActiveTypeFilter => activeContentTypes.Count > 0 && activeContentTypes.Count < ContentTypeCollections.Count;

    /// <summary>
    /// The regular (non-custom) collections that can be toggled as content type filters.
    /// </summary>
    private IReadOnlyList<TechHub.Core.Models.Collection> ContentTypeCollections =>
        section?.Collections.Where(c => !c.IsCustom).ToList() ?? [];

    /// <summary>
    /// The effective collection name to pass to ContentItemsGrid.
    /// Collection routes use the actual collection name, same as normal /section/collection pages.
    /// </summary>
    private string EffectiveCollectionName => CollectionName ?? "all";

    /// <summary>
    /// The content types to pass to the API for filtering.
    /// Only used on Browse page with content-type filter toggles.
    /// Returns null when all types are active (no filtering needed).
    /// </summary>
    private string? ActiveContentTypesParam
    {
        get
        {
            if (!IsAll) return null;

            // On Browse page with content type filter
            if (activeContentTypes.Count == 0 || activeContentTypes.Count == ContentTypeCollections.Count)
            {
                return null; // All types active = no filter needed
            }

            return string.Join(",", activeContentTypes);
        }
    }

    /// <summary>
    /// Key for the ContentItemsGrid component to force re-render on type changes.
    /// </summary>
    private string GridKey => $"{CollectionName}_{ActiveContentTypesParam}";

    private string PageTitleText => IsAll
        ? $"{section?.Title ?? SectionName} - Tech Hub"
        : $"{collection?.Title ?? CollectionName} - {section?.Title ?? SectionName} - Tech Hub";

    protected override void OnInitialized()
    {
        // Default to "all" when accessed via /{sectionName} route
        CollectionName ??= "all";

        // MainLayout has already validated sectionName and collectionName exist;
        // we just resolve the objects for rendering.
        section = SectionCache.GetSectionByName(SectionName)!;

        // Get collection (not applicable for "all")
        if (!IsAll)
        {
            collection = section.Collections.FirstOrDefault(c =>
                c.Name.Equals(CollectionName, StringComparison.OrdinalIgnoreCase));
        }

        // Parse tags and dates from URL
        ParseTagsFromUrl();
        ParseSearchFromUrl();
        ParseDatesFromUrl();
        ParseTypesFromUrl();

        // Initialize change tracking
        _previousSectionName = SectionName;
        _previousCollectionName = CollectionName;
    }

    protected override void OnParametersSet()
    {
        // Default to "all" when accessed via /{sectionName} route
        // Must be here (not just OnInitialized) because Blazor reuses the component
        // instance when navigating between /{sectionName} and /{sectionName}/{collectionName}
        CollectionName ??= "all";

        // Detect section/collection changes and reset filters
        var scopeChanged = !string.Equals(_previousSectionName, SectionName, StringComparison.OrdinalIgnoreCase)
            || !string.Equals(_previousCollectionName, CollectionName, StringComparison.OrdinalIgnoreCase);

        if (scopeChanged)
        {
            _previousSectionName = SectionName;
            _previousCollectionName = CollectionName;

            // Update section and collection references
            section = SectionCache.GetSectionByName(SectionName);
            collection = !IsAll
                ? section?.Collections.FirstOrDefault(c =>
                    c.Name.Equals(CollectionName, StringComparison.OrdinalIgnoreCase))
                : null;

            // Clear filters when navigating between collections
            selectedTags = new List<string>();
            searchQuery = string.Empty;
            fromDate = null;
            toDate = null;
            fromDateString = null;
            toDateString = null;
            activeContentTypes = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        }

        ParseTagsFromUrl();
        ParseSearchFromUrl();
        ParseDatesFromUrl();
        ParseTypesFromUrl();
    }

    private bool IsContentTypeActive(string collectionName)
    {
        // On Browse page: all active if no filter set, otherwise check the set
        return activeContentTypes.Count == 0 || activeContentTypes.Contains(collectionName);
    }

    private void ToggleContentType(string collectionName)
    {
        var allTypes = ContentTypeCollections.Select(c => c.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (activeContentTypes.Count == 0)
        {
            // Currently all active (empty set = all) — switch to all EXCEPT the clicked type
            activeContentTypes = new HashSet<string>(
                allTypes.Where(t => !string.Equals(t, collectionName, StringComparison.OrdinalIgnoreCase)),
                StringComparer.OrdinalIgnoreCase);
        }
        else if (activeContentTypes.Contains(collectionName))
        {
            // Don't allow deactivating the last type
            if (activeContentTypes.Count > 1)
            {
                activeContentTypes.Remove(collectionName);
            }
        }
        else
        {
            activeContentTypes.Add(collectionName);
            // If all types are now active, clear the set (no filter)
            if (activeContentTypes.Count == allTypes.Count)
            {
                activeContentTypes.Clear();
            }
        }

        UpdateUrl();
    }

    private void ParseTagsFromUrl()
    {
        if (!string.IsNullOrEmpty(TagsParam))
        {
            // Parse tags from URL, enforce limits matching API validation
            var rawTags = TagsParam.Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(t => Uri.UnescapeDataString(t.Trim()).ToLowerInvariant())
            .Where(t => t.Length <= 100)
            .Take(20)
            .ToList();

            // Deduplicate and normalize tags
            selectedTags = rawTags
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

            // If duplicates were removed or tags were truncated, clean up the URL
            if (rawTags.Count != selectedTags.Count)
            {
                UpdateUrl();
            }
        }
        else
        {
            selectedTags = new List<string>();
        }
    }

    private void ParseSearchFromUrl()
    {
        var raw = SearchParam ?? string.Empty;
        searchQuery = raw.Length > 200 ? raw[..200] : raw;
    }

    private void ParseDatesFromUrl()
    {
        fromDate = ParseDate(FromParam);
        toDate = ParseDate(ToParam);
        fromDateString = fromDate?.ToString("yyyy-MM-dd");
        toDateString = toDate?.ToString("yyyy-MM-dd");
    }

    private void ParseTypesFromUrl()
    {
        if (!string.IsNullOrEmpty(TypesParam) && IsAll)
        {
            var parsed = TypesParam.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            activeContentTypes = new HashSet<string>(parsed, StringComparer.OrdinalIgnoreCase);
        }
    }

    private static DateOnly? ParseDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return DateOnly.TryParse(value, out var date) ? date : null;
    }

    private void UpdateUrl()
    {
        var queryParams = new Dictionary<string, object?>
        {
            ["search"] = string.IsNullOrWhiteSpace(searchQuery) ? null : searchQuery,
            ["tags"] = selectedTags.Count > 0 ? string.Join(",", selectedTags) : null,
            ["from"] = fromDate?.ToString("yyyy-MM-dd"),
            ["to"] = toDate?.ToString("yyyy-MM-dd"),
            ["types"] = activeContentTypes.Count > 0 && activeContentTypes.Count < ContentTypeCollections.Count
                ? string.Join(",", activeContentTypes)
                : null
        };

        var url = Navigation.GetUriWithQueryParameters(queryParams);
        Navigation.NavigateTo(url, new NavigationOptions { ReplaceHistoryEntry = true });
    }

    private void HandleSearchQueryChanged(string query)
    {
        searchQuery = query;
        UpdateUrl();
    }

    private void HandleTagSelectionChanged(List<string> tags)
    {
        selectedTags = tags;
        UpdateUrl();
    }

    private void HandleDateRangeChanged(DateRangeChangedEventArgs args)
    {
        fromDate = args.FromDate;
        toDate = args.ToDate;
        fromDateString = fromDate?.ToString("yyyy-MM-dd");
        toDateString = toDate?.ToString("yyyy-MM-dd");
        UpdateUrl();
    }

    private string SeoDescription => IsAll
        ? section?.Description ?? $"Browse the latest content in {section?.Title ?? SectionName}"
        : collection?.Description ?? $"Browse {collection?.Title ?? CollectionName} in {section?.Title ?? SectionName}";

    private IReadOnlyList<SeoMetaTags.BreadcrumbItem> GetBreadcrumbs()
    {
        var items = new List<SeoMetaTags.BreadcrumbItem>
        {
            new("Home", "/")
        };

        if (section != null)
        {
            items.Add(new(section.Title, section.Url));
        }

        if (!IsAll && collection != null)
        {
            items.Add(new(collection.Title, $"{section?.Url}/{collection.Name}"));
        }

        return items;
    }
}