@page "/github-copilot/features"
@using TechHub.Core.Models
@using TechHub.Web.Services
@implements IDisposable
@inherits PageComponentBase

@inject ITechHubApiClient ApiClient
@inject NavigationManager Navigation
@inject ErrorService ErrorService
@inject ILogger<GitHubCopilotFeatures> Logger
@inject PersistentComponentState ApplicationState

<PageTitle>@(pageData?.Title ?? "GitHub Copilot Features") - Tech Hub</PageTitle>

@if (pageData != null)
{
    <SeoMetaTags
        Title="@pageData.Title"
        Description="@pageData.Description"
        ContentType="SeoMetaTags.SeoContentType.Website" />

    <main class="page-with-sidebar">
        <aside class="sidebar">
            <SidebarToggle />
            <MobileSidebarToolbar>
                <MobileSidebarPanel Label="Subscriptions" Icon="filter">
                    <nav class="sidebar-section features-tiers-sidebar" aria-label="Subscriptions">
                        <h2 class="sidebar-h2">Subscriptions</h2>
                        <div class="features-tiers-scroll">
                            @foreach (var tier in pageData.SubscriptionTiers)
                            {
                                <button type="button"
                                        id="tier-@tier.Id"
                                        class="features-tier-card @(activeTierId == tier.Id ? "active" : "")"
                                        data-initialized="blazor"
                                        @onclick="() => SetTierFilter(tier.Id)"
                                        @onclick:stopPropagation="true"
                                        @onclick:preventDefault="true">
                                    <h3>@tier.Name</h3>
                                    <p class="features-tier-tagline">@tier.Tagline</p>
                                    <ul class="features-tier-features">
                                        @foreach (var feature in tier.Features)
                                        {
                                            <li>@feature</li>
                                        }
                                    </ul>
                                    <span class="features-tier-link">View Features →</span>
                                </button>
                            }
                        </div>
                    </nav>
                </MobileSidebarPanel>
            </MobileSidebarToolbar>
        </aside>

        <article class="article-body">
            <div class="content-detail-header">
                <h1 id="skiptohere" class="page-h1">@pageData.Title</h1>
            </div>

            <div class="custom-page-container">
                <div class="custom-page-intro">
                    <p>@pageData.Intro For the most current pricing, visit <a href="@pageData.Links.Pricing" target="_blank" rel="noopener">GitHub's official pricing page</a>. For the most recent plan details, view the <a href="@pageData.Links.PlanDetails" target="_blank" rel="noopener">official documentation</a>.</p>
                    <p class="custom-page-note"><strong>Note:</strong> @pageData.Note</p>
                </div>

                @if (pageData.TimelineFeatures?.Count > 0)
                {
                    <div class="features-timeline-filters" role="group" aria-label="Filter features by subscription tier">
                        <button type="button"
                                class="features-filter-btn @(activeTierId == null && !ghesFilterActive ? "active" : "")"
                                data-initialized="blazor"
                                @onclick="ClearFilters"
                                @onclick:stopPropagation="true"
                                @onclick:preventDefault="true">All</button>
                        @foreach (var tier in pageData.SubscriptionTiers)
                        {
                            <button type="button"
                                    class="features-filter-btn @(activeTierId == tier.Id ? "active" : "")"
                                    data-initialized="blazor"
                                    @onclick="() => SetTierFilter(tier.Id)"
                                    @onclick:stopPropagation="true"
                                    @onclick:preventDefault="true">@tier.Name</button>
                        }
                        <button type="button"
                                class="features-filter-btn @(ghesFilterActive ? "active" : "")"
                                data-filter="ghes"
                                data-initialized="blazor"
                                @onclick="ToggleGhesFilter"
                                @onclick:stopPropagation="true"
                                @onclick:preventDefault="true">GHES Support</button>
                    </div>

                    @if (!GetFilteredTimeline().Any())
                    {
                        <p class="features-timeline-empty">No features match the selected filters.</p>
                    }
                    else
                    {
                        <div class="features-timeline" aria-label="GitHub Copilot feature timeline">
                            @foreach (var yearGroup in GetGroupedTimeline())
                            {
                                <div class="features-timeline-year-group">
                                    <div class="features-timeline-year-label" aria-label="Year @yearGroup.Key">
                                        <span>@yearGroup.Key</span>
                                    </div>
                                    @foreach (var feature in yearGroup.OrderByDescending(f => f.ReleaseDate))
                                    {
                                        var videoItem = GetVideoItem(feature.VideoSlug);
                                        var isExpanded = expandedFeatureId == feature.Id;
                                        var videoId = videoItem != null && !videoItem.Draft ? GetYouTubeVideoId(videoItem.ExternalUrl) : null;

                                        <div class="features-timeline-entry @(isExpanded ? "expanded" : "")" id="feature-@feature.Id">
                                            <div class="features-timeline-node" aria-hidden="true">
                                                <div class="features-timeline-dot"></div>
                                                <time class="features-timeline-date" datetime="@(feature.ReleaseDate + "-01")">@FormatReleaseDate(feature.ReleaseDate)</time>
                                            </div>
                                            <div class="features-timeline-card card">
                                                <button type="button"
                                                        class="features-timeline-header"
                                                        aria-expanded="@isExpanded.ToString().ToLowerInvariant()"
                                                        aria-controls="feature-detail-@feature.Id"
                                                        data-initialized="blazor"
                                                        @onclick="() => ToggleFeature(feature.Id)"
                                                        @onclick:stopPropagation="true"
                                                        @onclick:preventDefault="true">
                                                    <h3 class="features-timeline-name">@feature.Name</h3>
                                                    <div class="features-timeline-badges">
                                                        @foreach (var plan in feature.Plans)
                                                        {
                                                            <span class="badge-plan badge-plan-@GetPlanCssClass(plan)">@plan</span>
                                                        }
                                                        @if (feature.GhesSupport)
                                                        {
                                                            <span class="badge-success">✓ GHES</span>
                                                        }
                                                        @if (videoId != null)
                                                        {
                                                            <span class="badge-info">▶ Video</span>
                                                        }
                                                    </div>
                                                    <span class="features-timeline-expand-icon" aria-hidden="true">@(isExpanded ? "▲" : "▼")</span>
                                                </button>
                                                <p class="features-timeline-description">@feature.Description</p>

                                                <div id="feature-detail-@feature.Id" class="features-timeline-detail @(isExpanded ? "expanded" : "")">
                                                    @if (isExpanded)
                                                    {
                                                        @if (!string.IsNullOrEmpty(videoId))
                                                        {
                                                            <div class="features-timeline-video">
                                                                <a href="@videoItem!.GetHref(SectionName)" class="feature-card-thumbnail">
                                                                    <img src="https://img.youtube.com/vi/@videoId/mqdefault.jpg" alt="@feature.Name video thumbnail" loading="lazy" />
                                                                    <div class="feature-card-play-icon">
                                                                        <svg viewBox="0 0 24 24" fill="currentColor" width="40" height="40"><path d="M8 5v14l11-7z"/></svg>
                                                                    </div>
                                                                </a>
                                                                <a href="@videoItem!.GetHref(SectionName)" class="features-timeline-video-link">Watch full video →</a>
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </article>
    </main>
}
else if (_notFound)
{
    <NotFoundContent />
}

@code {
    private const string SectionName = "github-copilot";
    private FeaturesPageData? pageData;
    private bool _notFound;
    private List<TechHub.Core.Models.ContentItem> videoItems = new();
    private PersistingComponentStateSubscription? _persistSubscription;

    private string? activeTierId;
    private bool ghesFilterActive;
    private string? expandedFeatureId;

    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private void SetTierFilter(string tierId)
    {
        if (activeTierId == tierId)
        {
            activeTierId = null;
        }
        else
        {
            activeTierId = tierId;
        }
    }

    private void ToggleGhesFilter()
    {
        ghesFilterActive = !ghesFilterActive;
    }

    private void ClearFilters()
    {
        activeTierId = null;
        ghesFilterActive = false;
    }

    private void ToggleFeature(string featureId)
    {
        expandedFeatureId = expandedFeatureId == featureId ? null : featureId;
    }

    private IEnumerable<TimelineFeature> GetFilteredTimeline()
    {
        if (pageData?.TimelineFeatures == null)
        {
            return [];
        }

        IEnumerable<TimelineFeature> features = pageData.TimelineFeatures;

        if (activeTierId != null)
        {
            var tierName = pageData.SubscriptionTiers
                .FirstOrDefault(t => t.Id == activeTierId)?.Name;
            if (tierName != null)
            {
                features = features.Where(f => f.Plans.Contains(tierName, StringComparer.OrdinalIgnoreCase));
            }
        }

        if (ghesFilterActive)
        {
            features = features.Where(f => f.GhesSupport);
        }

        return features;
    }

    private List<IGrouping<string, TimelineFeature>> GetGroupedTimeline()
    {
        return GetFilteredTimeline()
            .OrderByDescending(f => f.ReleaseDate)
            .GroupBy(f => f.ReleaseDate.Length >= 4 ? f.ReleaseDate[..4] : f.ReleaseDate)
            .ToList();
    }

    private TechHub.Core.Models.ContentItem? GetVideoItem(string? videoSlug)
    {
        if (string.IsNullOrEmpty(videoSlug))
        {
            return null;
        }

        return videoItems.FirstOrDefault(v =>
            string.Equals(v.Slug, videoSlug, StringComparison.OrdinalIgnoreCase));
    }

    /// <summary>
    /// Extract YouTube video ID from a URL (supports youtu.be and youtube.com formats).
    /// </summary>
    private static string? GetYouTubeVideoId(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return null;
        }

        // youtu.be/VIDEO_ID
        if (url.Contains("youtu.be/", StringComparison.OrdinalIgnoreCase))
        {
            var uri = new Uri(url);
            return uri.AbsolutePath.TrimStart('/').Split('?')[0];
        }

        // youtube.com/watch?v=VIDEO_ID
        if (url.Contains("youtube.com", StringComparison.OrdinalIgnoreCase))
        {
            var uri = new Uri(url);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            return query["v"];
        }

        return null;
    }

    /// <summary>
    /// Formats a "YYYY-MM" release date string as a human-readable month abbreviation.
    /// </summary>
    private static string FormatReleaseDate(string releaseDate)
    {
        if (releaseDate.Length >= 7 &&
            int.TryParse(releaseDate[5..7], out var month) &&
            month is >= 1 and <= 12)
        {
            return System.Globalization.CultureInfo.InvariantCulture
                .DateTimeFormat.GetAbbreviatedMonthName(month);
        }

        return releaseDate;
    }

    /// <summary>
    /// Converts a subscription plan name to a CSS-safe class suffix (e.g. "Pro+" → "proplus").
    /// </summary>
    private static string GetPlanCssClass(string plan) =>
        plan.ToLowerInvariant().Replace("+", "plus", StringComparison.Ordinal);

    protected override async Task OnInitializedAsync()
    {
        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistState);

        if (ApplicationState.TryTakeFromJson<PersistedFeaturesData>("copilot-features-data", out var restored) && restored != null)
        {
            pageData = restored.PageData;
            videoItems = restored.VideoItems ?? new();
            return;
        }

        try
        {
            pageData = await ApiClient.GetFeaturesDataAsync();

            if (pageData == null)
            {
                _notFound = true;
                Activity.Current?.SetStatus(ActivityStatusCode.Error, "Content not found");
                if (HttpContext is not null)
                {
                    HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
                }
                return;
            }

            if (!string.IsNullOrEmpty(pageData.VideoCollection))
            {
                var allVideos = await ApiClient.GetGhcFeaturesAsync();
                videoItems = (allVideos ?? Enumerable.Empty<TechHub.Core.Models.ContentItem>())
                    .OrderByDescending(v => v.DateEpoch)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            ErrorService.HandleError(ex, Navigation, Logger);
        }
    }

    private Task PersistState()
    {
        ApplicationState.PersistAsJson("copilot-features-data", new PersistedFeaturesData
        {
            PageData = pageData,
            VideoItems = videoItems
        });
        return Task.CompletedTask;
    }

    private sealed class PersistedFeaturesData
    {
        public FeaturesPageData? PageData { get; set; }
        public List<TechHub.Core.Models.ContentItem>? VideoItems { get; set; }
    }

    public void Dispose()
    {
        _persistSubscription?.Dispose();
        GC.SuppressFinalize(this);
    }
}