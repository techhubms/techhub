@page "/github-copilot/features"
@using TechHub.Core.Models
@using TechHub.Web.Services
@implements IDisposable
@inherits PageComponentBase

@inject ITechHubApiClient ApiClient
@inject NavigationManager Navigation
@inject ErrorService ErrorService
@inject ILogger<GitHubCopilotFeatures> Logger
@inject PersistentComponentState ApplicationState

<PageTitle>@(pageData?.Title ?? "GitHub Copilot Features") - Tech Hub</PageTitle>

@if (pageData != null)
{
    <SeoMetaTags
        Title="@pageData.Title"
        Description="@pageData.Description"
        ContentType="SeoMetaTags.SeoContentType.Website" />

    <main class="page-with-sidebar">
        <aside class="sidebar">
            <SidebarToggle />
            <MobileSidebarToolbar>
                <MobileSidebarPanel Label="Subscriptions" Icon="filter">
                    <nav class="sidebar-section features-tiers-sidebar" aria-label="Subscriptions">
                        <h2 class="sidebar-h2">Subscriptions</h2>
                        <div class="features-tiers-scroll">
                            @foreach (var tier in pageData.SubscriptionTiers)
                            {
                                <button type="button"
                                        id="tier-@tier.Id"
                                        class="features-tier-card @(activeTierId == tier.Id ? "active" : "")"
                                        data-initialized="blazor"
                                        @onclick="() => SetTierFilter(tier.Id)"
                                        @onclick:stopPropagation="true"
                                        @onclick:preventDefault="true">
                                    <h3>@tier.Name</h3>
                                    <p class="features-tier-tagline">@tier.Tagline</p>
                                    <ul class="features-tier-features">
                                        @foreach (var feature in tier.Features)
                                        {
                                            <li>@feature</li>
                                        }
                                    </ul>
                                    <span class="features-tier-link">Filter timeline →</span>
                                </button>
                            }
                        </div>
                    </nav>
                </MobileSidebarPanel>
            </MobileSidebarToolbar>
        </aside>

        <article class="article-body">
            <div class="content-detail-header">
                <h1 id="skiptohere" class="page-h1">@pageData.Title</h1>
            </div>

            <div class="custom-page-container">
                <div class="custom-page-intro">
                    <p>@pageData.Intro For the most current pricing, visit <a href="@pageData.Links.Pricing" target="_blank" rel="noopener">GitHub's official pricing page</a>. For the most recent plan details, view the <a href="@pageData.Links.PlanDetails" target="_blank" rel="noopener">official documentation</a>.</p>
                    <p class="custom-page-note"><strong>Note:</strong> @pageData.Note</p>
                </div>

                @if (videoItems.Count > 0)
                {
                    <div class="features-timeline-filters" role="group" aria-label="Filter features by subscription tier">
                        <button type="button"
                                class="features-filter-btn @(activeTierId == null && !ghesFilterActive ? "active" : "")"
                                data-initialized="blazor"
                                @onclick="ClearFilters"
                                @onclick:stopPropagation="true"
                                @onclick:preventDefault="true">All</button>
                        @foreach (var tier in pageData.SubscriptionTiers)
                        {
                            <button type="button"
                                    class="features-filter-btn @(activeTierId == tier.Id ? "active" : "")"
                                    data-initialized="blazor"
                                    @onclick="() => SetTierFilter(tier.Id)"
                                    @onclick:stopPropagation="true"
                                    @onclick:preventDefault="true">@tier.Name</button>
                        }
                        <label class="features-ghes-toggle" data-filter="ghes">
                            <input type="checkbox"
                                   class="features-ghes-toggle-input"
                                   @bind="ghesFilterActive"
                                   data-initialized="blazor" />
                            <span class="features-ghes-toggle-track" aria-hidden="true">
                                <span class="features-ghes-toggle-thumb"></span>
                            </span>
                            <span class="features-ghes-toggle-label">GHES Support</span>
                        </label>
                    </div>

                    @if (!GetFilteredTimeline().Any())
                    {
                        <p class="features-timeline-empty">No features match the selected filters.</p>
                    }
                    else
                    {
                        <div class="features-timeline" aria-label="GitHub Copilot feature timeline">
                            @foreach (var yearGroup in GetGroupedTimeline())
                            {
                                <div class="features-timeline-year-group">
                                    <h2 class="features-timeline-year-label" aria-label="Year @yearGroup.Key">@yearGroup.Key</h2>
                                    <div class="features-timeline-year-entries">
                                        @foreach (var monthGroup in yearGroup.GroupBy(f => GetReleaseYearMonth(f)).OrderByDescending(g => g.Key))
                                        {
                                            <div class="features-timeline-month-row">
                                                <div class="features-timeline-node">
                                                    <div class="features-timeline-dot" aria-hidden="true"></div>
                                                    <time class="features-timeline-date" datetime="@(monthGroup.Key.Length == 7 ? monthGroup.Key + "-01" : "")">@FormatReleaseDate(monthGroup.Key)</time>
                                                </div>
                                                <div class="features-timeline-month-cards">
                                                    @foreach (var feature in monthGroup)
                                                    {
                                                        var thumbnailLink = feature.ThumbnailLink ?? feature.ContentLinks.FirstOrDefault();
                                                        var isExpanded = expandedFeatureId == feature.Slug;
                                                        var videoId = thumbnailLink != null ? GetYouTubeVideoId(thumbnailLink.ItemExternalUrl) : null;
                                                        var videoHref = thumbnailLink != null ? $"/{SectionName}/{thumbnailLink.CollectionName}/{thumbnailLink.ItemSlug}" : null;

                                                        <div class="features-timeline-entry @(isExpanded ? "expanded" : "")" id="feature-@feature.Slug">
                                                            <div class="features-timeline-card card"
                                                                 role="button"
                                                                 tabindex="0"
                                                                 aria-expanded="@isExpanded.ToString().ToLowerInvariant()"
                                                                 aria-controls="feature-detail-@feature.Slug"
                                                                 data-initialized="blazor"
                                                                 @onclick="() => ToggleFeature(feature.Slug)"
                                                                 @onkeydown="(e) => HandleFeatureKeyDown(e, feature.Slug)">
                                                                <div class="features-timeline-header">
                                                                    <div class="features-timeline-header-content">
                                                                        <h3 class="features-timeline-name">@feature.Title</h3>
                                                                        <div class="features-timeline-badges">
                                                                            @foreach (var plan in feature.Plans)
                                                                            {
                                                                                <span class="badge-plan badge-plan-@GetPlanCssClass(plan)">@plan</span>
                                                                            }
                                                                            @if (feature.GhesSupport)
                                                                            {
                                                                                <span class="badge-success">✓ GHES</span>
                                                                            }
                                                                            @if (feature.ContentLinks.Any(l => GetYouTubeVideoId(l.ItemExternalUrl) != null))
                                                                            {
                                                                                <span class="badge-info">▶ Video</span>
                                                                            }
                                                                        </div>
                                                                    </div>
                                                                    <span class="features-timeline-expand-icon" aria-hidden="true">▼</span>
                                                                </div>

                                                                <div id="feature-detail-@feature.Slug" class="features-timeline-detail @(isExpanded ? "expanded" : "")">
                                                                    <p class="features-timeline-description">@feature.Description</p>
                                                                    @if (!string.IsNullOrEmpty(videoId) && videoHref != null)
                                                                    {
                                                                        <div class="features-timeline-video">
                                                                            <a href="@videoHref" class="feature-card-thumbnail" @onclick:stopPropagation="true">
                                                                                <img src="https://img.youtube.com/vi/@videoId/mqdefault.jpg" alt="@feature.Title video thumbnail" loading="lazy" />
                                                                                <div class="feature-card-play-icon">
                                                                                    <svg viewBox="0 0 24 24" fill="currentColor" width="40" height="40"><path d="M8 5v14l11-7z"/></svg>
                                                                                </div>
                                                                            </a>
                                                                            <a href="@videoHref" class="features-timeline-video-link" @onclick:stopPropagation="true">Watch full video →</a>
                                                                        </div>
                                                                    }
                                                                    @{
                                                                        var relatedLinks = feature.ContentLinks
                                                                            .Where(l => !l.IsThumbnail)
                                                                            .OrderBy(l => l.SortOrder)
                                                                            .ToList();
                                                                    }
                                                                    @if (relatedLinks.Count > 0)
                                                                    {
                                                                        <div class="features-timeline-related" @onclick:stopPropagation="true">
                                                                            <p class="features-timeline-related-label">Related videos</p>
                                                                            <div class="features-timeline-related-grid">
                                                                                @foreach (var link in relatedLinks)
                                                                                {
                                                                                    var relVideoId = GetYouTubeVideoId(link.ItemExternalUrl);
                                                                                    var relHref = $"/{SectionName}/{link.CollectionName}/{link.ItemSlug}";
                                                                                    <a href="@relHref" class="features-timeline-related-card" @onclick:stopPropagation="true">
                                                                                        @if (!string.IsNullOrEmpty(relVideoId))
                                                                                        {
                                                                                            <div class="features-timeline-related-thumb">
                                                                                                <img src="https://img.youtube.com/vi/@relVideoId/mqdefault.jpg"
                                                                                                     alt="@link.ItemTitle"
                                                                                                     loading="lazy" />
                                                                                                <div class="features-timeline-related-play">
                                                                                                    <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M8 5v14l11-7z"/></svg>
                                                                                                </div>
                                                                                            </div>
                                                                                        }
                                                                                        <span class="features-timeline-related-card-title">@link.ItemTitle</span>
                                                                                    </a>
                                                                                }
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <p class="features-timeline-empty">No features are available at this time.</p>
                }
            </div>
        </article>
    </main>
}
else if (_notFound)
{
    <NotFoundContent />
}

@code {
    private const string SectionName = "github-copilot";
    private FeaturesPageData? pageData;
    private bool _notFound;
    private List<GhcFeature> videoItems = new();
    private PersistingComponentStateSubscription? _persistSubscription;

    private string? activeTierId;
    private bool ghesFilterActive;
    private string? expandedFeatureId;

    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private async Task SetTierFilter(string tierId)
    {
        activeTierId = activeTierId == tierId ? null : tierId;
        await JS.InvokeVoidAsync("scrollTierCardIntoView", activeTierId);
    }

    private async Task ClearFilters()
    {
        activeTierId = null;
        ghesFilterActive = false;
        await JS.InvokeVoidAsync("scrollTierCardIntoView", (object?)null);
    }

    private void ToggleFeature(string featureSlug)
    {
        expandedFeatureId = expandedFeatureId == featureSlug ? null : featureSlug;
    }

    private void HandleFeatureKeyDown(KeyboardEventArgs e, string featureSlug)
    {
        if (e.Key == "Enter" || e.Key == " ")
        {
            ToggleFeature(featureSlug);
        }
    }

    /// <summary>Converts a GhcFeature's release date (Unix epoch) to a "YYYY-MM" string for grouping.</summary>
    private static string GetReleaseYearMonth(GhcFeature f)
    {
        if (!f.ReleaseDate.HasValue)
        {
            return "TBA";
        }

        var date = DateTimeOffset.FromUnixTimeSeconds(f.ReleaseDate.Value).UtcDateTime;
        return $"{date.Year:D4}-{date.Month:D2}";
    }

    private IEnumerable<GhcFeature> GetFilteredTimeline()
    {
        IEnumerable<GhcFeature> features = videoItems;

        if (activeTierId != null)
        {
            var tierName = pageData?.SubscriptionTiers
                .FirstOrDefault(t => t.Id == activeTierId)?.Name;
            if (tierName != null)
            {
                features = features.Where(f => f.Plans.Contains(tierName, StringComparer.OrdinalIgnoreCase));
            }
        }

        if (ghesFilterActive)
        {
            features = features.Where(f => f.GhesSupport);
        }

        return features;
    }

    private List<IGrouping<string, GhcFeature>> GetGroupedTimeline()
    {
        return GetFilteredTimeline()
            .OrderByDescending(f => f.ReleaseDate ?? 0)
            .GroupBy(f => f.ReleaseDate.HasValue
                ? DateTimeOffset.FromUnixTimeSeconds(f.ReleaseDate.Value).UtcDateTime.Year.ToString()
                : "TBA")
            .ToList();
    }

    /// <summary>
    /// Extract YouTube video ID from a URL (supports youtu.be and youtube.com formats).
    /// </summary>
    private static string? GetYouTubeVideoId(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return null;
        }

        // youtu.be/VIDEO_ID
        if (url.Contains("youtu.be/", StringComparison.OrdinalIgnoreCase))
        {
            var uri = new Uri(url);
            return uri.AbsolutePath.TrimStart('/').Split('?')[0];
        }

        // youtube.com/watch?v=VIDEO_ID
        if (url.Contains("youtube.com", StringComparison.OrdinalIgnoreCase))
        {
            var uri = new Uri(url);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            return query["v"];
        }

        return null;
    }

    /// <summary>
    /// Formats a "YYYY-MM" release date string as a human-readable month abbreviation.
    /// </summary>
    private static string FormatReleaseDate(string releaseDate)
    {
        if (releaseDate.Length >= 7 &&
            int.TryParse(releaseDate[5..7], out var month) &&
            month is >= 1 and <= 12)
        {
            return System.Globalization.CultureInfo.InvariantCulture
                .DateTimeFormat.GetAbbreviatedMonthName(month);
        }

        return releaseDate;
    }

    /// <summary>
    /// Converts a subscription plan name to a CSS-safe class suffix (e.g. "Pro+" → "proplus").
    /// </summary>
    private static string GetPlanCssClass(string plan) =>
        plan.ToLowerInvariant().Replace("+", "plus", StringComparison.Ordinal);

    protected override async Task OnInitializedAsync()
    {
        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistState);

        if (ApplicationState.TryTakeFromJson<PersistedFeaturesData>("copilot-features-data", out var restored) && restored != null)
        {
            pageData = restored.PageData;
            videoItems = restored.VideoItems ?? new();
            expandedFeatureId = videoItems.FirstOrDefault()?.Slug;
            return;
        }

        try
        {
            pageData = await ApiClient.GetFeaturesDataAsync();

            if (pageData == null)
            {
                _notFound = true;
                Activity.Current?.SetStatus(ActivityStatusCode.Error, "Content not found");
                if (HttpContext is not null)
                {
                    HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
                }
                return;
            }

            var allFeatures = await ApiClient.GetGhcFeaturesAsync();
            videoItems = (allFeatures ?? Enumerable.Empty<GhcFeature>())
                .OrderByDescending(f => f.ReleaseDate ?? 0)
                .ToList();
            expandedFeatureId = videoItems.FirstOrDefault()?.Slug;
        }
        catch (Exception ex)
        {
            ErrorService.HandleError(ex, Navigation, Logger);
        }
    }

    private Task PersistState()
    {
        ApplicationState.PersistAsJson("copilot-features-data", new PersistedFeaturesData
        {
            PageData = pageData,
            VideoItems = videoItems
        });
        return Task.CompletedTask;
    }

    private sealed class PersistedFeaturesData
    {
        public FeaturesPageData? PageData { get; set; }
        public List<GhcFeature>? VideoItems { get; set; }
    }

    public void Dispose()
    {
        _persistSubscription?.Dispose();
        GC.SuppressFinalize(this);
    }
}