@page "/github-copilot/features"
@using TechHub.Core.Models
@using TechHub.Web.Services
@implements IDisposable

@inject IJSRuntime JS
@inject ITechHubApiClient ApiClient
@inject NavigationManager Navigation
@inject ErrorService ErrorService
@inject ILogger<GitHubCopilotFeatures> Logger
@inject PersistentComponentState ApplicationState

<PageTitle>@(pageData?.Title ?? "GitHub Copilot Features") - Tech Hub</PageTitle>

@if (pageData != null)
{
    <SeoMetaTags
        Title="@pageData.Title"
        Description="@pageData.Description"
        ContentType="SeoMetaTags.SeoContentType.Website" />

    <main class="page-with-sidebar">
        <aside class="sidebar">
            <SidebarToggle />
            <MobileSidebarToolbar>
                <MobileSidebarPanel Label="Subscriptions" Icon="filter">
                    <nav class="sidebar-section features-tiers-sidebar" aria-label="Subscriptions">
                        <h2 class="sidebar-h2">Subscriptions</h2>
                        <div class="features-tiers-scroll">
                            @foreach (var tier in pageData.SubscriptionTiers)
                            {
                                <a href="/github-copilot/features#timeline" id="tier-@tier.Id" class="features-tier-card">
                                    <h3>@tier.Name</h3>
                                    <p class="features-tier-tagline">@tier.Tagline</p>
                                    <ul class="features-tier-features">
                                        @foreach (var feature in tier.Features)
                                        {
                                            <li>@feature</li>
                                        }
                                    </ul>
                                    <span class="features-tier-link">View Features →</span>
                                </a>
                            }
                        </div>
                    </nav>
                </MobileSidebarPanel>
            </MobileSidebarToolbar>
        </aside>

        <article class="article-body">
            <div class="content-detail-header">
                <h1 id="skiptohere" class="page-h1">@pageData.Title</h1>
            </div>

            <div class="custom-page-container">
                <div class="custom-page-intro">
                    <p>@pageData.Intro For the most current pricing, visit <a href="@pageData.Links.Pricing" target="_blank" rel="noopener">GitHub's official pricing page</a>. For the most recent plan details, view the <a href="@pageData.Links.PlanDetails" target="_blank" rel="noopener">official documentation</a>.</p>
                    <p class="custom-page-note"><strong>Note:</strong> @pageData.Note</p>
                </div>

                @if (pageData.TimelineFeatures.Count > 0)
                {
                    var visibleItems = GetVisibleItems();

                    <section class="features-timeline-section" aria-label="Feature timeline">
                        <h2 id="timeline" class="features-timeline-heading">Feature Timeline</h2>
                        <p class="features-timeline-subtitle">A chronological history of GitHub Copilot features — filter by subscription tier or GHES support.</p>

                        <div class="features-timeline-filters" role="group" aria-label="Timeline filters">
                            <button type="button"
                                    class="features-filter-btn @(activeFilters.Contains("ghes") ? "active" : "")"
                                    @onclick='() => ToggleFilter("ghes")'
                                    aria-pressed="@activeFilters.Contains("ghes").ToString().ToLower()">
                                GHES Support
                            </button>
                            @foreach (var tier in AllTiers)
                            {
                                <button type="button"
                                        class="features-filter-btn @(activeFilters.Contains(tier) ? "active" : "")"
                                        @onclick='() => ToggleFilter(tier)'
                                        aria-pressed="@activeFilters.Contains(tier).ToString().ToLower()">
                                    @tier
                                </button>
                            }
                            @if (activeFilters.Count > 0)
                            {
                                <button type="button" class="features-filter-btn features-filter-clear" @onclick="ClearFilters">
                                    Clear filters ×
                                </button>
                            }
                        </div>

                        <div class="features-timeline" id="timeline-list" aria-live="polite">
                            @if (visibleItems.Count == 0)
                            {
                                <p class="features-timeline-empty">No features match the selected filters.</p>
                            }
                            else
                            {
                                @foreach (var item in visibleItems)
                                {
                                    var isExpanded = expandedItems.Contains(item.Id);
                                    var videoItem = GetVideoForFeature(item.VideoSlug);

                                    <div class="features-timeline-item @(isExpanded ? "expanded" : "")"
                                         data-ghes="@item.GhesSupport.ToString().ToLower()"
                                         data-tiers="@string.Join(",", item.Tiers).ToLower()">
                                        <div class="features-timeline-marker" aria-hidden="true">
                                            <div class="features-timeline-dot"></div>
                                            <div class="features-timeline-line"></div>
                                        </div>
                                        <div class="features-timeline-content">
                                            <button type="button"
                                                    class="features-timeline-header"
                                                    @onclick='() => ToggleExpand(item.Id)'
                                                    aria-expanded="@isExpanded.ToString().ToLower()">
                                                <div class="features-timeline-meta">
                                                    <time class="features-timeline-date" datetime="@item.ReleaseDate">
                                                        @FormatDate(item.ReleaseDate)
                                                    </time>
                                                    @if (!string.IsNullOrEmpty(item.Category))
                                                    {
                                                        <span class="badge badge-category">@item.Category</span>
                                                    }
                                                </div>
                                                <h3 class="features-timeline-title">@item.Title</h3>
                                                <div class="features-timeline-badges">
                                                    @foreach (var tier in item.Tiers)
                                                    {
                                                        <span class="badge badge-tier">@tier</span>
                                                    }
                                                    @if (item.GhesSupport)
                                                    {
                                                        <span class="badge-success">✓ GHES</span>
                                                    }
                                                </div>
                                                <span class="features-timeline-toggle-icon" aria-hidden="true">@(isExpanded ? "▲" : "▼")</span>
                                            </button>

                                            @if (isExpanded)
                                            {
                                                <div class="features-timeline-detail">
                                                    <p class="features-timeline-description">@item.Description</p>

                                                    @if (videoItem != null)
                                                    {
                                                        var videoId = GetYouTubeVideoId(videoItem.ExternalUrl);
                                                        @if (!string.IsNullOrEmpty(videoId))
                                                        {
                                                            <a href="@videoItem.GetHref(SectionName)" class="features-timeline-video-link feature-card" aria-label="Watch video: @videoItem.Title">
                                                                <div class="feature-card-thumbnail">
                                                                    <img src="https://img.youtube.com/vi/@videoId/mqdefault.jpg" alt="" loading="lazy" />
                                                                    <div class="feature-card-play-icon">
                                                                        <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32"><path d="M8 5v14l11-7z"/></svg>
                                                                    </div>
                                                                </div>
                                                                <div class="card-header">
                                                                    <span class="card-title features-timeline-video-title">@videoItem.Title</span>
                                                                </div>
                                                            </a>
                                                        }
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </section>
                }

                @* Legacy feature sections — kept for video browsing by plan *@
                @foreach (var featureSection in pageData.FeatureSections)
                {
                    var sectionVideos = videoItems.Where(v =>
                        featureSection.Plans.Any(p => v.Plans.Contains(p, StringComparer.OrdinalIgnoreCase)))
                        .OrderBy(v => v.Title)
                        .ToList();

                    @if (sectionVideos.Count > 0)
                    {
                        <div class="features-video-section">
                            <h2 id="@featureSection.Id">@featureSection.Title</h2>
                            <div class="features-section-filters">
                                <button type="button" class="features-filter-btn" data-filter="ghes">GHES Support</button>
                                <button type="button" class="features-filter-btn" data-filter="videos">With videos</button>
                            </div>
                            <div class="features-cards-grid">
                                @foreach (var feature in sectionVideos)
                                {
                                    var featureId = $"feature-{feature.Slug}";
                                    var videoId = GetYouTubeVideoId(feature.ExternalUrl);

                                    @if (!string.IsNullOrEmpty(videoId))
                                    {
                                        <a href="@feature.GetHref(SectionName)" class="card feature-card" data-ghes="@feature.GhesSupport.ToString().ToLower()" data-has-video="true">
                                            <div class="feature-card-thumbnail">
                                                <img src="https://img.youtube.com/vi/@videoId/mqdefault.jpg" alt="" loading="lazy" />
                                                <div class="feature-card-play-icon">
                                                    <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32"><path d="M8 5v14l11-7z"/></svg>
                                                </div>
                                            </div>
                                            <div class="card-header">
                                                <h3 id="@featureId" class="card-title">@feature.Title</h3>
                                            </div>
                                            <p class="card-description" title="@feature.Excerpt">@TruncateText(feature.Excerpt, 135)</p>
                                            <div class="card-badges">
                                                @if (feature.GhesSupport)
                                                {
                                                    <span class="badge-success">✓ GHES</span>
                                                }
                                                <span class="badge-info">▶ Video</span>
                                            </div>
                                        </a>
                                    }
                                    else
                                    {
                                        <div class="card feature-card feature-card-static" data-ghes="@feature.GhesSupport.ToString().ToLower()" data-has-video="false">
                                            <div class="card-header">
                                                <h3 id="@featureId" class="card-title">@feature.Title</h3>
                                            </div>
                                            <p class="card-description" title="@feature.Excerpt">@feature.Excerpt</p>
                                            <div class="card-badges">
                                                @if (feature.GhesSupport)
                                                {
                                                    <span class="badge-success">✓ GHES</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </article>
    </main>
}

@code {
    private const string SectionName = "github-copilot";

    private static readonly string[] AllTiers = ["Free", "Student", "Pro", "Business", "Pro+", "Enterprise"];

    private FeaturesPageData? pageData;
    private List<TechHub.Core.Models.ContentItem> videoItems = new();
    private HashSet<string> activeFilters = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> expandedItems = new(StringComparer.OrdinalIgnoreCase);
    private PersistingComponentStateSubscription? _persistSubscription;

    private List<FeatureTimelineItem> GetVisibleItems()
    {
        if (pageData == null) return [];

        var items = pageData.TimelineFeatures
            .OrderByDescending(f => f.ReleaseDate)
            .AsEnumerable();

        if (activeFilters.Contains("ghes"))
            items = items.Where(f => f.GhesSupport);

        var tierFilters = activeFilters
            .Where(f => AllTiers.Contains(f, StringComparer.OrdinalIgnoreCase))
            .ToList();

        if (tierFilters.Count > 0)
            items = items.Where(f => f.Tiers.Any(t => tierFilters.Contains(t, StringComparer.OrdinalIgnoreCase)));

        return [.. items];
    }

    private void ToggleFilter(string filter)
    {
        if (!activeFilters.Remove(filter))
            activeFilters.Add(filter);
    }

    private void ClearFilters() => activeFilters.Clear();

    private void ToggleExpand(string id)
    {
        if (!expandedItems.Remove(id))
            expandedItems.Add(id);
    }

    private TechHub.Core.Models.ContentItem? GetVideoForFeature(string? videoSlug)
    {
        if (string.IsNullOrEmpty(videoSlug)) return null;
        return videoItems.FirstOrDefault(v =>
            string.Equals(v.Slug, videoSlug, StringComparison.OrdinalIgnoreCase));
    }

    /// <summary>
    /// Format an ISO date string as "Month YYYY" (e.g. "June 2022").
    /// </summary>
    private static string FormatDate(string isoDate)
    {
        if (DateOnly.TryParse(isoDate, out var date))
            return date.ToString("MMMM yyyy");
        return isoDate;
    }

    /// <summary>
    /// Extract YouTube video ID from a URL (supports youtu.be and youtube.com formats).
    /// </summary>
    private static string? GetYouTubeVideoId(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return null;

        if (url.Contains("youtu.be/", StringComparison.OrdinalIgnoreCase))
        {
            var uri = new Uri(url);
            return uri.AbsolutePath.TrimStart('/').Split('?')[0];
        }

        if (url.Contains("youtube.com", StringComparison.OrdinalIgnoreCase))
        {
            var uri = new Uri(url);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            return query["v"];
        }

        return null;
    }

    private static string TruncateText(string? text, int maxLength)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLength)
            return text ?? string.Empty;

        return text[..maxLength] + "...";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (pageData != null)
        {
            await JS.InvokeVoidAsync("markScriptsLoading");
            await JS.InvokeVoidAsync("initCustomPages");
            await JS.InvokeVoidAsync("markScriptsReady");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistState);

        if (ApplicationState.TryTakeFromJson<PersistedFeaturesData>("copilot-features-data", out var restored) && restored != null)
        {
            pageData = restored.PageData;
            videoItems = restored.VideoItems ?? new();
            return;
        }

        try
        {
            pageData = await ApiClient.GetFeaturesDataAsync();

            if (pageData == null)
            {
                Navigation.NavigateTo("/not-found");
                return;
            }

            if (!string.IsNullOrEmpty(pageData.VideoCollection))
            {
                var allVideos = await ApiClient.GetGhcFeaturesAsync();
                videoItems = (allVideos ?? Enumerable.Empty<TechHub.Core.Models.ContentItem>())
                    .OrderByDescending(v => v.DateEpoch)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            ErrorService.HandleError(ex, Navigation, Logger);
        }
    }

    private Task PersistState()
    {
        ApplicationState.PersistAsJson("copilot-features-data", new PersistedFeaturesData
        {
            PageData = pageData,
            VideoItems = videoItems
        });
        return Task.CompletedTask;
    }

    private sealed class PersistedFeaturesData
    {
        public FeaturesPageData? PageData { get; set; }
        public List<TechHub.Core.Models.ContentItem>? VideoItems { get; set; }
    }

    public void Dispose()
    {
        _persistSubscription?.Dispose();
        GC.SuppressFinalize(this);
    }
}
