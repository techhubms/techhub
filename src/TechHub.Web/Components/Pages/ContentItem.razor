@page "/{sectionName}/{collectionName}/{slug}"
@using TechHub.Core.Configuration
@using TechHub.Core.Models
@using TechHub.Core.Validation
@using TechHub.Web.Services
@implements IDisposable
@inherits PageComponentBase

@inject ITechHubApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>@(item?.Title ?? "Not Found") - Tech Hub</PageTitle>

@if (!isLoading && item == null)
{
    <NotFoundContent />
}
else
{

@if (item != null)
{
    <SeoMetaTags
        Title="@item.Title"
        Description="@item.Excerpt"
        ContentType="@GetSeoContentType()"
        Author="@item.Author"
        DateEpoch="@item.DateEpoch"
        Keywords="@item.Tags"
        ArticleSection="@GetSectionTitle()"
        VideoUrl="@GetVideoUrl()"
        ImageUrl="@GetOgImageUrl()"
        Breadcrumbs="@GetBreadcrumbs()" />
}

<main class="page-with-sidebar">
    <aside class="sidebar">
        <SidebarToggle />
        <MobileSidebarToolbar>
        @if (item != null)
        {
            @* Tag cloud showing this content item's tags with real section counts (structural tags excluded) *@
            <MobileSidebarPanel Label="Tags" Icon="tags">
            <SidebarTagCloud Tags="@GetFilteredTags()"
                SectionName="@SectionName"
                Title="Tags" NavigationMode="TagCloudNavigationMode.Navigate"
                NavigationBaseUrl="@($"/{SectionName.ToLowerInvariant()}")" />
            </MobileSidebarPanel>
            <MobileSidebarPanel Label="Table of Contents" Icon="toc">
            <SidebarToc HtmlContent="@item.RenderedHtml" Title="Table of Contents" />
            </MobileSidebarPanel>
        }
        </MobileSidebarToolbar>
    </aside>

    @* Main content area *@
    @if (item != null)
    {
        <ContentItemDetail Item="@item" />
    }
</main>

}

@code {
    [Inject] public required ErrorService ErrorService { get; set; }
    [Inject] public required ILogger<ContentItem> Logger { get; set; }
    [Inject] public required SectionCache SectionCache { get; set; }
    [Inject] public required PersistentComponentState ApplicationState { get; set; }

    private PersistingComponentStateSubscription? _persistSubscription;

    [Parameter]
    public string SectionName { get; set; } = null!;

    [Parameter]
    public string CollectionName { get; set; } = null!;

    [Parameter]
    public string Slug { get; set; } = null!;

    private TechHub.Core.Models.ContentItemDetail? item;
    private TechHub.Core.Models.Section? section;
    private bool isLoading = true;
    private string? _previousSectionName;
    private string? _previousCollectionName;
    private string? _previousSlug;

    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    protected override IReadOnlyList<string> PageScripts => ["initHighlighting", "initMermaid", "initTocScrollSpy"];
    protected override bool IsPageDataReady => item != null;
    protected override bool IsNotFound => !isLoading && item == null;
    protected override bool ReinitializeScriptsOnRerender => true;

    protected override async Task OnInitializedAsync()
    {
        // Validate route parameters before any API calls
        if (!RouteParameterValidator.IsValidNameSegment(SectionName)
            || !RouteParameterValidator.IsValidNameSegment(CollectionName)
            || !RouteParameterValidator.IsValidSlug(Slug))
        {
            Activity.Current?.SetStatus(ActivityStatusCode.Error, "Content not found");
            if (HttpContext is not null)
            {
                HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
            }
            isLoading = false;
            return;
        }

        // Verify section exists
        section = SectionCache.GetSectionByName(SectionName);
        if (section == null)
        {
            Activity.Current?.SetStatus(ActivityStatusCode.Error, "Content not found");
            if (HttpContext is not null)
            {
                HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
            }
            isLoading = false;
            return;
        }

        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistState);

        // Initialize change-tracking fields from current parameter values
        _previousSectionName = SectionName;
        _previousCollectionName = CollectionName;
        _previousSlug = Slug;

        if (!string.IsNullOrEmpty(SectionName) && !string.IsNullOrEmpty(CollectionName) && !string.IsNullOrEmpty(Slug))
        {
            await LoadItem();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // Only reload when route parameters actually change (e.g., navigating between content items)
        if (SectionName != _previousSectionName || CollectionName != _previousCollectionName || Slug != _previousSlug)
        {
            _previousSectionName = SectionName;
            _previousCollectionName = CollectionName;
            _previousSlug = Slug;

            // Validate route parameters on every parameter change
            if (!RouteParameterValidator.IsValidNameSegment(SectionName)
                || !RouteParameterValidator.IsValidNameSegment(CollectionName)
                || !RouteParameterValidator.IsValidSlug(Slug))
            {
                item = null;
                Activity.Current?.SetStatus(ActivityStatusCode.Error, "Content not found");
                if (HttpContext is not null)
                {
                    HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
                }
                isLoading = false;
                return;
            }

            section = SectionCache.GetSectionByName(SectionName);
            if (section == null)
            {
                item = null;
                Activity.Current?.SetStatus(ActivityStatusCode.Error, "Content not found");
                if (HttpContext is not null)
                {
                    HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
                }
                isLoading = false;
                return;
            }

            await LoadItem();
        }
    }

    private async Task LoadItem()
    {
        try
        {
            isLoading = true;

            var stateKey = $"content-item-{SectionName}-{CollectionName}-{Slug}";
            if (ApplicationState.TryTakeFromJson<TechHub.Core.Models.ContentItemDetail>(stateKey, out var restored) && restored != null)
            {
                item = restored;
                return;
            }

            item = await ApiClient.GetContentDetailAsync(SectionName.ToLowerInvariant(), CollectionName.ToLowerInvariant(),
            Slug.ToLowerInvariant());

            if (item == null)
            {
                // Content not found - the template renders not-found content inline.
                Activity.Current?.SetStatus(ActivityStatusCode.Error, "Content not found");
                if (HttpContext is not null)
                {
                    HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
                }
            }
        }
        catch (Exception ex)
        {
            ErrorService.HandleError(ex, Navigation, Logger);
        }
        finally
        {
            isLoading = false;
        }
    }

    private Task PersistState()
    {
        if (item != null)
        {
            var stateKey = $"content-item-{SectionName}-{CollectionName}-{Slug}";
            ApplicationState.PersistAsJson(stateKey, item);
        }
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _persistSubscription?.Dispose();
        GC.SuppressFinalize(this);
    }

    private SeoMetaTags.SeoContentType GetSeoContentType() =>
        item?.CollectionName == "videos" ? SeoMetaTags.SeoContentType.Video : SeoMetaTags.SeoContentType.Article;

    private string? _ogImageUrl;

    private string? GetOgImageUrl()
    {
        if (_ogImageUrl is not null)
            return _ogImageUrl == string.Empty ? null : _ogImageUrl;

        string? url = null;

        if (item?.CollectionName == "videos")
        {
            var videoUrl = item.ExternalUrl;
            if (!string.IsNullOrEmpty(videoUrl))
                url = SeoMetaTags.TryGetYouTubeThumbnailUrl(videoUrl)
                    ?? "/images/section-backgrounds/none-og.jpg";
        }
        else if (item?.CollectionName == "roundups")
        {
            url = "/images/section-backgrounds/none-og.jpg";
        }

        // Cache: use empty string to sentinel-encode a null result
        _ogImageUrl = url ?? string.Empty;
        return url;
    }

    private string? GetSectionTitle() => section?.Title;

    private string? GetVideoUrl() => item?.CollectionName == "videos" ? item?.ExternalUrl : null;

    /// <summary>
    /// Filters out structural tags (section titles, collection names, high-frequency noise)
    /// from the content item's tags so they don't clutter the sidebar tag cloud.
    /// Mirrors the exclude logic in ContentRepository.BuildExcludeTagsSetAsync.
    /// </summary>
    private IReadOnlyList<string> GetFilteredTags()
    {
        if (item?.Tags == null || item.Tags.Count == 0)
        {
            return [];
        }

        var excludeSet = BuildStructuralTagsExcludeSet();
        return item.Tags
            .Where(t => !excludeSet.Contains(t))
            .ToList();
    }

    private HashSet<string>? _structuralTagsCache;

    private HashSet<string> BuildStructuralTagsExcludeSet()
    {
        if (_structuralTagsCache != null)
        {
            return _structuralTagsCache;
        }

        var sectionTags = SectionCache.Sections
            .Select(s => s.Tag)
            .Where(t => !string.IsNullOrWhiteSpace(t))
            .Select(t => t!);

        var collectionTags = SectionCache.Sections
            .SelectMany(s => s.Collections)
            .Select(c => Collection.GetTagFromName(c.Name))
            .Where(t => !string.IsNullOrWhiteSpace(t));

        _structuralTagsCache = TagExclusions.BuildExcludeSet(sectionTags, collectionTags);
        return _structuralTagsCache;
    }

    private IReadOnlyList<SeoMetaTags.BreadcrumbItem> GetBreadcrumbs()
    {
        if (item == null)
        {
            return [];
        }

        var items = new List<SeoMetaTags.BreadcrumbItem>
        {
            new("Home", "/")
        };

        if (section != null)
        {
            items.Add(new(section.Title, section.Url));

            var collection = section.Collections.FirstOrDefault(c =>
                c.Name.Equals(CollectionName, StringComparison.OrdinalIgnoreCase));

            if (collection != null)
            {
                items.Add(new(collection.Title, $"{section.Url}/{collection.Name}"));
            }
        }

        items.Add(new(item.Title, item.GetHref(SectionName)));

        return items;
    }
}