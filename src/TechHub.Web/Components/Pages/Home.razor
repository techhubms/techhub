@page "/"
@using TechHub.Core.Models
@using TechHub.Web.Services
@implements IDisposable
@inherits PageComponentBase
@inject ITechHubApiClient ApiClient
@inject NavigationManager Navigation
@inject ErrorService ErrorService
@inject ILogger<Home> Logger
@inject PersistentComponentState ApplicationState
@inject HomepageStatsState HomepageStats

<PageTitle>Tech Hub - Microsoft Technology News & Resources</PageTitle>

<SeoMetaTags
    Title="Tech Hub - Microsoft Technology News & Resources"
    Description="Discover the latest Microsoft technology news, GitHub Copilot updates, AI developments, and developer resources — curated and published daily."
    ContentType="SeoMetaTags.SeoContentType.Website"
    RssFeedUrl="/all/feed.xml" />

<main class="page-with-sidebar">
    @* Sidebar (Left Column) *@
    <aside class="sidebar">
        <SidebarToggle />
        <MobileSidebarToolbar>
        @* Latest Roundups (one per section) - always visible, including on mobile *@
        @if (latestRoundups != null && latestRoundups.Any())
        {
            <div class="sidebar-section latest-roundups">
                <h2 class="sidebar-h2">Latest Roundups</h2>
                <ul class="sidebar-list">
                    @foreach (var roundup in latestRoundups)
                    {
                        <li>
                            <a href="@roundup.GetHref()"
                               class="sidebar-content-button"
                               target="@roundup.GetTarget()"
                               rel="@roundup.GetRel()"
                               aria-label="@roundup.GetAriaLabel()">
                                <span class="sidebar-content-button-title">@StripRoundupPrefix(roundup.Title)</span>
                                <span class="sidebar-content-button-meta">
                                    <span class="sidebar-item-section">@GetItemSectionTitle(roundup.PrimarySectionName)</span>
                                    <span class="sidebar-content-button-meta-separator">•</span>
                                    <span class="sidebar-item-date">@FormatDateShort(roundup.DateEpoch)</span>
                                </span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        }

        <MobileSidebarPanel Label="Latest" Icon="latest">
        @* Latest Items *@
        @if (latestItems != null && latestItems.Any())
        {
            <div class="sidebar-section latest-items">
                <h2 class="sidebar-h2">Latest Content</h2>
                <ul class="sidebar-list">
                    @foreach (var item in latestItems)
                    {
                        <li>
                            <a href="@item.GetHref()"
                                class="sidebar-content-button"
                                target="@item.GetTarget()"
                                rel="@item.GetRel()"
                                aria-label="@item.GetAriaLabel()">
                                <span class="sidebar-content-button-title">@item.Title</span>
                                <span class="sidebar-content-button-meta">
                                    <span class="sidebar-item-section">@GetItemSectionTitle(item.PrimarySectionName)</span>
                                    <span class="sidebar-content-button-meta-separator">•</span>
                                    <span
                                        class="sidebar-item-collection">@GetItemCollectionTitle(item.CollectionName)</span>
                                    <span class="sidebar-content-button-meta-separator">•</span>
                                    <span class="sidebar-item-date">@FormatDateShort(item.DateEpoch)</span>
                                </span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        }
        </MobileSidebarPanel>

        @* Popular Tags - Navigate to /all with tag filter *@
        <MobileSidebarPanel Label="Tags" Icon="tags">
        <SidebarTagCloud Title="Popular Tags"
            NavigationMode="TagCloudNavigationMode.Navigate" NavigationBaseUrl="/all" />
        </MobileSidebarPanel>
        </MobileSidebarToolbar>
    </aside>

    <section class="home-main-content">
        @if (sections != null && sections.Any())
        {
            <SectionCardsGrid Sections="@sections" />
        }
        else
        {
            <div class="no-content">
                <p>No sections available.</p>
            </div>
        }
    </section>
</main>

@code {

    private PersistingComponentStateSubscription? _persistSubscription;

    private IEnumerable<TechHub.Core.Models.Section>? sections;
    private IEnumerable<TechHub.Core.Models.ContentItem>? latestRoundups;
    private IEnumerable<TechHub.Core.Models.ContentItem>? latestItems;
    private long? recentCount;
    private long? totalCount;

    private static readonly TimeZoneInfo BrusselsTz =
        TimeZoneInfo.TryFindSystemTimeZoneById("Europe/Brussels", out var tz) ? tz : TimeZoneInfo.Utc;
    private static string WeekAgoDate => TimeZoneInfo.ConvertTime(DateTimeOffset.UtcNow, BrusselsTz)
        .AddDays(-7).ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture);

    private string GetItemSectionTitle(string sectionName)
    {
        var section = sections?.FirstOrDefault(s => s.Name.Equals(sectionName, StringComparison.OrdinalIgnoreCase));
        return section?.Title ?? sectionName;
    }

    private string GetItemCollectionTitle(string collectionName)
    {
        // Search all sections for the collection
        foreach (var section in sections ?? Enumerable.Empty<TechHub.Core.Models.Section>())
        {
            var collection = section.Collections.FirstOrDefault(c => 
                c.Name.Equals(collectionName, StringComparison.OrdinalIgnoreCase));
            if (collection != null)
            {
                return collection.DisplayName ?? collection.Title;
            }
        }
        // Fallback to title case
        return System.Globalization.CultureInfo.InvariantCulture.TextInfo.ToTitleCase(collectionName.ToLowerInvariant());
    }

    protected override IReadOnlyList<string> PageScripts => ["initCustomPages"];
    protected override bool IsPageDataReady => sections != null;

protected override async Task OnInitializedAsync()
{
    _persistSubscription = ApplicationState.RegisterOnPersisting(PersistState);

    if (ApplicationState.TryTakeFromJson<PersistedHomeData>("home-data", out var restored) && restored != null)
    {
        sections = restored.Sections;
        latestRoundups = restored.LatestRoundups;
        latestItems = restored.LatestItems;
        recentCount = restored.RecentCount;
        totalCount = restored.TotalCount;
        UpdateSubNavStats();
        return;
    }

try
{
// Fetch all content in parallel - sections first, then roundups per section + latest items
var sectionsTask = ApiClient.GetAllSectionsAsync();
var latestItemsTask = ApiClient.GetLatestItemsAsync(count: 5);
var recentItemsTask = ApiClient.GetCollectionItemsAsync("all", "all", take: 1, fromDate: WeekAgoDate);
var allItemsTask = ApiClient.GetCollectionItemsAsync("all", "all", take: 1);

await Task.WhenAll(sectionsTask, latestItemsTask, recentItemsTask, allItemsTask);

sections = await sectionsTask;
latestItems = await latestItemsTask;
recentCount = (await recentItemsTask)?.TotalCount;
totalCount = (await allItemsTask)?.TotalCount;

// Fetch latest roundup per section (requires sections to determine which have roundups)
latestRoundups = await ApiClient.GetLatestRoundupPerSectionAsync(sections ?? [], CancellationToken.None);
UpdateSubNavStats();
}
catch (Exception ex)
{
ErrorService.HandleError(ex, Navigation, Logger);
}
}

    private Task PersistState()
    {
        ApplicationState.PersistAsJson("home-data", new PersistedHomeData
        {
            Sections = sections?.ToList(),
            LatestRoundups = latestRoundups?.ToList(),
            LatestItems = latestItems?.ToList(),
            RecentCount = recentCount,
            TotalCount = totalCount
        });
        return Task.CompletedTask;
    }

    private sealed class PersistedHomeData
    {
        public List<TechHub.Core.Models.Section>? Sections { get; set; }
        public List<TechHub.Core.Models.ContentItem>? LatestRoundups { get; set; }
        public List<TechHub.Core.Models.ContentItem>? LatestItems { get; set; }
        public long? RecentCount { get; set; }
        public long? TotalCount { get; set; }
    }

    public void Dispose()
    {
        _persistSubscription?.Dispose();
        GC.SuppressFinalize(this);
    }

    private void UpdateSubNavStats()
    {
        HomepageStats.Update(recentCount, totalCount, WeekAgoDate, sections?.Count() ?? 0);
    }

    private static string FormatDateShort(long epochSeconds) => DateHelper.FormatDateRelative(epochSeconds);

    private static string StripRoundupPrefix(string title)
    {
        var colonIndex = title.IndexOf(": ", StringComparison.Ordinal);
        return colonIndex >= 0 ? title[(colonIndex + 2)..] : title;
    }
}
