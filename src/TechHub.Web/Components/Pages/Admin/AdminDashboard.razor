@page "/admin"
@layout AdminLayout
@rendermode InteractiveServer
@using TechHub.Core.Models.Admin
@using TechHub.Web.Services
@implements IDisposable
@inject ITechHubApiClient Api
@inject NavigationManager Navigation
@inject PersistentComponentState ApplicationState
@inject ILogger<AdminDashboard> Logger

<PageTitle>Admin Dashboard — TechHub</PageTitle>

<div class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Content Processing</h1>
            <p class="admin-page-subtitle">Manage RSS feed ingestion and AI categorization</p>
        </div>
        <div class="admin-actions">
            <button class="btn" @onclick="TriggerRunAsync" disabled="@_triggering">
                @if (_triggering)
                {
                    <span>Triggering…</span>
                }
                else
                {
                    <span>▶ Run Now</span>
                }
            </button>
            <button class="btn-secondary" @onclick="LoadJobsAsync">⟳ Refresh</button>
        </div>
    </div>

    @if (_triggerMessage != null)
    {
        <div class="admin-alert @(_triggerError ? "admin-alert-error" : "admin-alert-success")" role="alert">
            @_triggerMessage
        </div>
    }

    @if (_loading)
    {
        <div class="admin-loading">Loading job history…</div>
    }
    else if (_error != null)
    {
        <div class="admin-alert admin-alert-error" role="alert">@_error</div>
    }
    else if (_jobs == null || _jobs.Count == 0)
    {
        <div class="admin-empty">No processing jobs yet. Click <strong>Run Now</strong> to start the first run.</div>
    }
    else
    {
        <div class="admin-jobs-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Started</th>
                        <th>Duration</th>
                        <th>Trigger</th>
                        <th>Status</th>
                        <th>Added</th>
                        <th>Skipped</th>
                        <th>Errors</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in _jobs)
                    {
                        <tr>
                            <td class="admin-cell-mono">@job.Id</td>
                            <td>@FormatTimestamp(job.StartedAt)</td>
                            <td>@FormatDuration(job.DurationMs)</td>
                            <td>
                                <span class="admin-badge admin-badge-@job.TriggerType">@job.TriggerType</span>
                            </td>
                            <td>
                                <span class="admin-status admin-status-@job.Status">
                                    @StatusIcon(job.Status) @job.Status
                                </span>
                            </td>
                            <td class="admin-cell-number">@job.ItemsAdded</td>
                            <td class="admin-cell-number">@job.ItemsSkipped</td>
                            <td class="admin-cell-number @(job.ErrorCount > 0 ? "admin-cell-error" : "")">
                                @job.ErrorCount
                            </td>
                            <td>
                                @if (_expandedJobId == job.Id)
                                {
                                    <button class="admin-link-btn" @onclick="() => CollapseLog()">Hide log</button>
                                }
                                else
                                {
                                    <button class="admin-link-btn" @onclick="() => ExpandLog(job.Id)">View log</button>
                                }
                            </td>
                        </tr>
                        @if (_expandedJobId == job.Id && !string.IsNullOrWhiteSpace(job.LogOutput))
                        {
                            <tr class="admin-log-row">
                                <td colspan="9">
                                    <pre class="admin-log">@job.LogOutput</pre>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private bool _triggering;
    private string? _error;
    private string? _triggerMessage;
    private bool _triggerError;
    private IReadOnlyList<ContentProcessingJob>? _jobs;
    private long? _expandedJobId;
    private PersistingComponentStateSubscription? _persistSubscription;
    private CancellationTokenSource? _pollCts;

    protected override async Task OnInitializedAsync()
    {
        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistState);

        if (ApplicationState.TryTakeFromJson<IReadOnlyList<ContentProcessingJob>>("admin-dashboard-jobs", out var restored) && restored != null)
        {
            _jobs = restored;
            _loading = false;
            StartPollingIfRunning();
            return;
        }

        await LoadJobsAsync();
        StartPollingIfRunning();
    }

    private Task PersistState()
    {
        if (_jobs != null)
        {
            ApplicationState.PersistAsJson("admin-dashboard-jobs", _jobs);
        }
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _persistSubscription?.Dispose();
        StopPolling();
    }

    private async Task LoadJobsAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _jobs = await Api.GetProcessingJobsAsync();
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            // Token cache expired (e.g. after server restart) — redirect to re-authenticate
            Navigation.NavigateTo("/MicrosoftIdentity/Account/SignIn?redirectUri=%2Fadmin", forceLoad: true);
            return;
        }
        catch (HttpRequestException ex)
        {
            _error = $"Failed to load jobs: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task TriggerRunAsync()
    {
        _triggering = true;
        _triggerMessage = null;

        try
        {
            await Api.TriggerContentProcessingAsync();
            _triggerError = false;

            // Give the API a moment to create the job, then reload and start live polling
            await Task.Delay(500);
            await LoadJobsAsync();
            AutoExpandRunningJob();
            StartPollingIfRunning();
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (HttpRequestException ex)
        {
            _triggerMessage = $"Failed to trigger run: {ex.Message}";
            _triggerError = true;
        }
        finally
        {
            _triggering = false;
        }
    }

    private void ExpandLog(long jobId)
    {
        _expandedJobId = jobId;
    }

    private void CollapseLog()
    {
        _expandedJobId = null;
    }

    private static string FormatTimestamp(DateTimeOffset timestamp) =>
        DateHelper.FormatTimestamp(timestamp);

    private static string FormatDuration(long? durationMs)
    {
        if (durationMs == null) return "—";
        var ts = TimeSpan.FromMilliseconds(durationMs.Value);
        return ts.TotalMinutes >= 1
            ? $"{(int)ts.TotalMinutes}m {ts.Seconds}s"
            : $"{ts.TotalSeconds:F1}s";
    }

    private static string StatusIcon(string status) => status switch
    {
        ContentProcessingJobStatus.Running => "⏳",
        ContentProcessingJobStatus.Completed => "✅",
        ContentProcessingJobStatus.Failed => "❌",
        _ => "❓"
    };

    private bool HasRunningJob =>
        _jobs?.Any(j => j.Status == ContentProcessingJobStatus.Running) == true;

    private void AutoExpandRunningJob()
    {
        var running = _jobs?.FirstOrDefault(j => j.Status == ContentProcessingJobStatus.Running);
        if (running != null)
        {
            _expandedJobId = running.Id;
        }
    }

    private void StartPollingIfRunning()
    {
        if (!HasRunningJob || _pollCts != null)
        {
            return;
        }

        _pollCts = new CancellationTokenSource();
        _ = PollLoopAsync(_pollCts.Token);
    }

    private void StopPolling()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollCts = null;
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(3));

            while (await timer.WaitForNextTickAsync(ct))
            {
                try
                {
                    _jobs = await Api.GetProcessingJobsAsync(cancellationToken: ct);
                    AutoExpandRunningJob();
                    await InvokeAsync(StateHasChanged);

                    if (!HasRunningJob)
                    {
                        break;
                    }
                }
                catch (OperationCanceledException)
                {
                    break;
                }
                catch (Exception ex)
                {
                    Logger.LogDebug(ex, "Polling for job updates failed, will retry");
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Expected on dispose
        }
        finally
        {
            StopPolling();
        }
    }
}
