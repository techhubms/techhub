@page "/admin"
@layout AdminLayout
@rendermode InteractiveServer
@using TechHub.Core.Models.Admin
@using TechHub.Web.Services
@implements IDisposable
@inject ITechHubApiClient Api
@inject PersistentComponentState ApplicationState
@inject ILogger<AdminDashboard> Logger

<PageTitle>Admin Dashboard — TechHub</PageTitle>

<div class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Background Tasks</h1>
            <p class="admin-page-subtitle">Unified overview of RSS content processing and weekly roundup generation</p>
        </div>
        <div class="admin-actions">
            <button class="btn" @onclick="TriggerProcessingAsync" disabled="@_triggeringProcessing">
                @if (_triggeringProcessing)
                {
                    <span>Triggering…</span>
                }
                else
                {
                    <span>▶ Run Processing</span>
                }
            </button>
            <button class="btn" @onclick="TriggerRoundupAsync" disabled="@_triggeringRoundup">
                @if (_triggeringRoundup)
                {
                    <span>Triggering…</span>
                }
                else
                {
                    <span>▶ Run Roundup</span>
                }
            </button>
            <button class="btn" @onclick="TriggerContentFixerAsync" disabled="@_triggeringContentFixer">
                @if (_triggeringContentFixer)
                {
                    <span>Triggering…</span>
                }
                else
                {
                    <span>▶ Run Cleanup</span>
                }
            </button>
            @if (HasRunningJob)
            {
                <button class="btn-danger" @onclick="CancelRunningJobAsync" disabled="@_cancelling">
                    @if (_cancelling)
                    {
                        <span>Cancelling…</span>
                    }
                    else
                    {
                        <span>⏹ Cancel Running</span>
                    }
                </button>
            }
            <button class="btn-secondary" @onclick="LoadJobsAsync">⟳ Refresh</button>
        </div>
    </div>

    @if (_triggerMessage != null)
    {
        <div class="admin-alert @(_triggerError ? "admin-alert-error" : "admin-alert-success")" role="alert">
            @_triggerMessage
        </div>
    }

    @if (_loading)
    {
        <div class="admin-loading">Loading job history…</div>
    }
    else if (_error != null)
    {
        <div class="admin-alert admin-alert-error" role="alert">@_error</div>
    }
    else if (_jobs == null || _jobs.Count == 0)
    {
        <div class="admin-empty">No processing jobs yet. Click <strong>Run Now</strong> to start the first run.</div>
    }
    else
    {
        <div class="admin-jobs-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Type</th>
                        <th>Started</th>
                        <th>Duration</th>
                        <th>Trigger</th>
                        <th>Status</th>
                        <th class="admin-cell-number">Added</th>
                        <th class="admin-cell-number">Skipped</th>
                        <th class="admin-cell-number">Errors</th>
                        <th class="admin-cell-number">Fixed</th>
                        <th class="admin-cell-number">Transcripts</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in _jobs)
                    {
                        <tr>
                            <td class="admin-cell-mono">@job.Id</td>
                            <td>
                                <span class="admin-badge admin-badge-@JobTypeBadge(job.JobType)">@JobTypeLabel(job.JobType)</span>
                            </td>
                            <td>@FormatTimestamp(job.StartedAt)</td>
                            <td>@FormatDuration(job.DurationMs, job.Status == ContentProcessingJobStatus.Running ? job.StartedAt : null)</td>
                            <td>
                                <span class="admin-badge admin-badge-@job.TriggerType">@job.TriggerType</span>
                            </td>
                            <td>
                                <span class="admin-status admin-status-@job.Status">
                                    @StatusIcon(job.Status) @job.Status
                                </span>
                            </td>
                            <td class="admin-cell-number">
                                @if (job.JobType == ContentProcessingJobType.ContentCleanup)
                                {
                                    <span>—</span>
                                }
                                else
                                {
                                    @job.ItemsAdded
                                }
                            </td>
                            <td class="admin-cell-number">
                                @if (job.JobType == ContentProcessingJobType.ContentCleanup)
                                {
                                    <span>—</span>
                                }
                                else
                                {
                                    @job.ItemsSkipped
                                }
                            </td>
                            <td class="admin-cell-number @(job.ErrorCount > 0 ? "admin-cell-error" : "")">
                                @job.ErrorCount
                            </td>
                            <td class="admin-cell-number">
                                @if (job.JobType == ContentProcessingJobType.ContentCleanup)
                                {
                                    @job.ItemsFixed
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </td>
                            <td class="admin-cell-number">
                                @if (job.JobType is ContentProcessingJobType.ContentProcessing or ContentProcessingJobType.AdHocProcessing)
                                {
                                    if (job.TranscriptsSucceeded > 0 || job.TranscriptsFailed > 0)
                                    {
                                        <span title="@job.TranscriptsSucceeded succeeded, @job.TranscriptsFailed failed">@job.TranscriptsSucceeded ✓ @job.TranscriptsFailed ✗</span>
                                    }
                                    else
                                    {
                                        <span>—</span>
                                    }
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </td>
                            <td>
                                @if (job.JobType != ContentProcessingJobType.ContentCleanup)
                                {
                                    <a class="admin-link-btn" href="@($"/admin/processed-urls?jobId={job.Id}")"
                                       title="Show URLs processed by this job">View Processed</a>
                                }
                                @if (_expandedJobId == job.Id)
                                {
                                    <button class="admin-link-btn" @onclick="() => CollapseLog()">Hide log</button>
                                }
                                else
                                {
                                    <button class="admin-link-btn" @onclick="() => ExpandLog(job.Id)">View log</button>
                                }
                            </td>
                        </tr>
                        @if (_expandedJobId == job.Id && _expandedLogOutput != null)
                        {
                            <tr class="admin-log-row">
                                <td colspan="12">
                                    <pre class="admin-log">@_expandedLogOutput</pre>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private bool _triggeringProcessing;
    private bool _triggeringRoundup;
    private bool _triggeringContentFixer;
    private bool _cancelling;
    private string? _error;
    private string? _triggerMessage;
    private bool _triggerError;
    private IReadOnlyList<ContentProcessingJob>? _jobs;
    private long? _expandedJobId;
    private string? _expandedLogOutput;
    private PersistingComponentStateSubscription? _persistSubscription;
    private CancellationTokenSource? _pollCts;

    protected override async Task OnInitializedAsync()
    {
        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistState);

        if (ApplicationState.TryTakeFromJson<IReadOnlyList<ContentProcessingJob>>("admin-dashboard-jobs", out var restored) && restored != null)
        {
            _jobs = restored;
            _loading = false;
        }
        else
        {
            await LoadJobsAsync();
        }

        StartPollingIfRunning();
    }

    private Task PersistState()
    {
        if (_jobs != null)
        {
            ApplicationState.PersistAsJson("admin-dashboard-jobs", _jobs);
        }
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _persistSubscription?.Dispose();
        StopPolling();
    }

    private async Task LoadJobsAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _jobs = await Api.GetProcessingJobsAsync();
        }
        catch (HttpRequestException ex)
        {
            _error = $"Failed to load jobs: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }

        StartPollingIfRunning();
    }

    private async Task TriggerProcessingAsync()
    {
        _triggeringProcessing = true;
        _triggerMessage = null;

        try
        {
            await Api.TriggerContentProcessingAsync();
            _triggerError = false;

            await Task.Delay(500);
            await LoadJobsAsync();
            StartPollingIfRunning();
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (HttpRequestException ex)
        {
            _triggerMessage = $"Failed to trigger processing: {ex.Message}";
            _triggerError = true;
        }
        finally
        {
            _triggeringProcessing = false;
        }
    }

    private async Task TriggerRoundupAsync()
    {
        _triggeringRoundup = true;
        _triggerMessage = null;

        try
        {
            await Api.TriggerRoundupGenerationAsync();
            _triggerError = false;

            await Task.Delay(500);
            await LoadJobsAsync();
            StartPollingIfRunning();
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (HttpRequestException ex)
        {
            _triggerMessage = $"Failed to trigger roundup generation: {ex.Message}";
            _triggerError = true;
        }
        finally
        {
            _triggeringRoundup = false;
        }
    }

    private async Task TriggerContentFixerAsync()
    {
        _triggeringContentFixer = true;
        _triggerMessage = null;

        try
        {
            await Api.TriggerContentFixerAsync();
            _triggerError = false;

            await Task.Delay(500);
            await LoadJobsAsync();
            StartPollingIfRunning();
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (HttpRequestException ex)
        {
            _triggerMessage = $"Failed to trigger content fixer: {ex.Message}";
            _triggerError = true;
        }
        finally
        {
            _triggeringContentFixer = false;
        }
    }

    private async Task CancelRunningJobAsync()
    {
        _cancelling = true;
        _triggerMessage = null;

        try
        {
            await Api.CancelRunningJobAsync();
            _triggerMessage = "Cancellation requested — job will stop shortly.";
            _triggerError = false;

            await Task.Delay(1000);
            await LoadJobsAsync();
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (HttpRequestException ex)
        {
            _triggerMessage = $"Failed to cancel job: {ex.Message}";
            _triggerError = true;
        }
        finally
        {
            _cancelling = false;
        }
    }

    private async Task ExpandLog(long jobId)
    {
        _expandedJobId = jobId;
        _expandedLogOutput = null;

        try
        {
            var job = await Api.GetProcessingJobByIdAsync(jobId);
            _expandedLogOutput = job?.LogOutput ?? "(no log output)";
        }
        catch (HttpRequestException ex)
        {
            _expandedLogOutput = $"Failed to load log: {ex.Message}";
        }
    }

    private void CollapseLog()
    {
        _expandedJobId = null;
        _expandedLogOutput = null;
    }

    private static string FormatTimestamp(DateTimeOffset timestamp) =>
        DateHelper.FormatTimestamp(timestamp);

    private static string FormatDuration(long? durationMs, DateTimeOffset? runningStartedAt = null)
    {
        TimeSpan ts;
        if (runningStartedAt != null)
        {
            ts = DateTimeOffset.UtcNow - runningStartedAt.Value;
        }
        else if (durationMs != null)
        {
            ts = TimeSpan.FromMilliseconds(durationMs.Value);
        }
        else
        {
            return "—";
        }

        return ts.TotalMinutes >= 1
            ? $"{(int)ts.TotalMinutes}m {ts.Seconds}s"
            : $"{ts.TotalSeconds:F1}s";
    }

    private static string StatusIcon(string status) => status switch
    {
        ContentProcessingJobStatus.Running => "⏳",
        ContentProcessingJobStatus.Completed => "✅",
        ContentProcessingJobStatus.Failed => "❌",
        ContentProcessingJobStatus.Aborted => "⛔",
        _ => "❓"
    };

    private static string JobTypeLabel(string jobType) => jobType switch
    {
        ContentProcessingJobType.ContentProcessing => "Processing",
        ContentProcessingJobType.RoundupGeneration => "Roundup",
        ContentProcessingJobType.ContentCleanup => "Cleanup",
        ContentProcessingJobType.AdHocProcessing => "Ad-hoc",
        _ => jobType
    };

    private static string JobTypeBadge(string jobType) => jobType switch
    {
        ContentProcessingJobType.ContentProcessing => "processing",
        ContentProcessingJobType.RoundupGeneration => "roundup",
        ContentProcessingJobType.ContentCleanup => "cleanup",
        ContentProcessingJobType.AdHocProcessing => "adhoc",
        _ => "unknown"
    };

    private bool HasRunningJob =>
        _jobs?.Any(j => j.Status == ContentProcessingJobStatus.Running) == true;

    private void StartPollingIfRunning()
    {
        if (!HasRunningJob || _pollCts != null)
        {
            return;
        }

        _pollCts = new CancellationTokenSource();
        _ = PollLoopAsync(_pollCts.Token);
    }

    private void StopPolling()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollCts = null;
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(3));

            while (await timer.WaitForNextTickAsync(ct))
            {
                try
                {
                    _jobs = await Api.GetProcessingJobsAsync(cancellationToken: ct);

                    // Auto-refresh the expanded log if viewing a running job
                    if (_expandedJobId != null)
                    {
                        var expandedJob = _jobs?.FirstOrDefault(j => j.Id == _expandedJobId);
                        if (expandedJob?.Status == ContentProcessingJobStatus.Running)
                        {
                            var job = await Api.GetProcessingJobByIdAsync(_expandedJobId.Value, ct);
                            _expandedLogOutput = job?.LogOutput ?? _expandedLogOutput;
                        }
                    }

                    await InvokeAsync(StateHasChanged);

                    if (!HasRunningJob)
                    {
                        break;
                    }
                }
                catch (OperationCanceledException)
                {
                    break;
                }
                catch (Exception ex)
                {
                    Logger.LogDebug(ex, "Polling for job updates failed, will retry");
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Expected on dispose
        }
        finally
        {
            StopPolling();
        }
    }
}
