@page "/admin/copilot-features"
@layout AdminLayout
@rendermode InteractiveServer
@using TechHub.Core.Models
@using TechHub.Core.Models.Admin
@using TechHub.Web.Services
@implements IDisposable
@inject ITechHubApiClient Api
@inject PersistentComponentState ApplicationState
@inject ILogger<AdminCopilotFeatures> Logger
@inherits PageComponentBase

<PageTitle>Copilot Features — TechHub Admin</PageTitle>

<div class="admin-page">
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Copilot Features</h1>
            <p class="admin-page-subtitle">Manage GitHub Copilot features — description, release date, plans, GHES support, and linked content</p>
        </div>
        <div class="admin-actions">
            <button class="btn-secondary" @onclick="LoadFeaturesAsync">⟳ Refresh</button>
        </div>
    </div>

    @if (_message != null)
    {
        <div class="admin-alert @(_messageIsError ? "admin-alert-error" : "admin-alert-success")" role="alert">
            @_message
        </div>
    }

    @if (_loading)
    {
        <div class="admin-loading">Loading features…</div>
    }
    else if (_error != null)
    {
        <div class="admin-alert admin-alert-error" role="alert">@_error</div>
    }
    else if (_items == null || _items.Count == 0)
    {
        <div class="admin-empty">No GitHub Copilot features found.</div>
    }
    else
    {
        <div class="admin-result-summary">@_items.Count feature@(_items.Count == 1 ? "" : "s")</div>

        <div class="admin-jobs-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Slug</th>
                        <th>Release</th>
                        <th class="features-plans-col">Plans</th>
                        <th>GHES</th>
                        <th>Content Links</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _items)
                    {
                        <tr>
                            <td class="admin-cell-article" title="@item.Title">
                                <span class="features-title-text">@item.Title</span>
                            </td>
                            <td class="admin-cell-mono" title="@item.Slug">@item.Slug</td>
                            <td class="admin-cell-mono">
                                @if (item.ReleaseDate is long ts)
                                {
                                    @DateTimeOffset.FromUnixTimeSeconds(ts).ToString("yyyy-MM-dd")
                                }
                                else
                                {
                                    <span style="color:var(--color-text-secondary)">—</span>
                                }
                            </td>
                            <td>
                                <div class="features-plans-badges">
                                    @foreach (var plan in item.Plans)
                                    {
                                        <span class="features-plan-badge features-plan-badge-@plan.ToLowerInvariant().Replace("+", "plus").Replace(" ", "-")">@plan</span>
                                    }
                                </div>
                            </td>
                            <td>
                                @if (item.GhesSupport)
                                {
                                    <span class="badge-success">✓</span>
                                }
                                else
                                {
                                    <span class="admin-cell-mono">—</span>
                                }
                            </td>
                            <td>@item.ContentLinks.Count link@(item.ContentLinks.Count == 1 ? "" : "s")</td>
                            <td>
                                <button class="admin-link-btn" @onclick="() => OpenEditor(item)">Edit</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* ── Editor modal ── *@
@if (_editorOpen && _editing != null)
{
    var editing = _editing;
    <div class="admin-modal-backdrop" @onclick="CloseEditor">
        <div class="admin-modal admin-modal-wide" @onclick:stopPropagation>
            <div class="admin-modal-header">
                <h2 class="admin-modal-title">Edit Feature — @editing.Slug</h2>
                <button class="admin-modal-close" @onclick="CloseEditor" aria-label="Close">✕</button>
            </div>

            <div class="admin-modal-body">

                @* ── Metadata ── *@
                <div class="features-editor-field">
                    <label class="admin-label" for="edit-description">Description</label>
                    <textarea id="edit-description" class="admin-input features-description-textarea"
                              @bind="_editingDescription" rows="4"
                              placeholder="Short description of the feature…"></textarea>
                </div>

                <div class="features-editor-field">
                    <label class="admin-label" for="edit-release-date">Release Date</label>
                    <div class="features-date-row">
                        <input id="edit-release-date" type="date" class="admin-input features-date-input"
                               value="@_editingReleaseDate"
                               @onchange="e => _editingReleaseDate = e.Value?.ToString()" />
                        <span class="features-field-hint">Leave blank if not yet released.</span>
                    </div>
                </div>

                @* ── Plans ── *@
                <fieldset class="features-plans-fieldset">
                    <legend class="features-plans-legend">Subscription Plans</legend>
                    <div class="features-plans-checkboxes">
                        @foreach (var plan in _allPlans)
                        {
                            var planChecked = _editingPlans.Contains(plan);
                            <label class="features-plan-checkbox-label">
                                <input type="checkbox"
                                       checked="@planChecked"
                                       @onchange="() => TogglePlan(plan)" />
                                <span class="features-plan-badge features-plan-badge-@plan.ToLowerInvariant().Replace("+", "plus").Replace(" ", "-")">@plan</span>
                            </label>
                        }
                    </div>
                </fieldset>

                <div class="features-editor-options">
                    <label class="features-ghes-label">
                        <input type="checkbox" @bind="_editingGhesSupport" />
                        <span>GHES Support</span>
                    </label>
                </div>

                @* ── Content links ── *@
                <div class="features-links-section">
                    <h3 class="features-links-heading">Content Links</h3>

                    @if (_linkMessage != null)
                    {
                        <div class="admin-alert @(_linkMessageIsError ? "admin-alert-error" : "admin-alert-success")" role="alert">@_linkMessage</div>
                    }

                    @if (_editingLinks.Count == 0)
                    {
                        <p class="features-links-empty">No content links yet.</p>
                    }
                    else
                    {
                        <div class="admin-jobs-table-wrapper">
                        <table class="admin-table features-links-table">
                            <thead>
                                <tr>
                                    <th>Thumb</th>
                                    <th>Title</th>
                                    <th>Slug</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var link in _editingLinks.OrderBy(l => l.SortOrder).ThenBy(l => l.ItemSlug))
                                {
                                    var l = link;
                                    <tr>
                                        <td class="admin-cell-mono features-link-thumb-cell">
                                            @if (l.IsThumbnail)
                                            {
                                                <span class="badge-success" title="This is the thumbnail">★</span>
                                            }
                                            else
                                            {
                                                <button class="admin-link-btn" title="Set as thumbnail"
                                                        @onclick="() => SetThumbnailAsync(l)" disabled="@_saving">☆</button>
                                            }
                                        </td>
                                        <td class="admin-cell-article" title="@l.ItemTitle">
                                            @if (!string.IsNullOrEmpty(l.ItemExternalUrl))
                                            {
                                                <a href="@l.ItemExternalUrl" target="_blank" rel="noopener noreferrer">@(l.ItemTitle ?? l.ItemSlug)</a>
                                            }
                                            else
                                            {
                                                @(l.ItemTitle ?? l.ItemSlug)
                                            }
                                        </td>
                                        <td class="admin-cell-mono">@l.CollectionName/@l.ItemSlug</td>
                                        <td>
                                            <button class="admin-link-btn admin-link-btn-danger"
                                                    @onclick="() => RemoveLinkAsync(l)" disabled="@_saving">Remove</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                    }

                    @* ── Add link search ── *@
                    <div class="features-links-add">
                        <h4 class="features-links-add-heading">Add Content Link</h4>
                        <div class="features-links-search-row">
                            <input type="text" class="admin-input features-links-search-input"
                                   @bind="_linkSearchQuery"
                                   placeholder="Search by title or slug…" />
                            <select class="admin-input features-links-collection-select"
                                    @bind="_linkSearchCollection">
                                <option value="">All collections</option>
                                <option value="videos">videos</option>
                                <option value="blogs">blogs</option>
                                <option value="news">news</option>
                            </select>
                            <button class="btn-secondary" @onclick="SearchContentItemsAsync"
                                    disabled="@_linkSearchLoading">
                                @(_linkSearchLoading ? "Searching…" : "Search")
                            </button>
                        </div>

                        @if (_linkSearchError != null)
                        {
                            <div class="admin-alert admin-alert-error" role="alert">@_linkSearchError</div>
                        }

                        @if (_linkSearchResults.Count > 0)
                        {
                            <div class="admin-jobs-table-wrapper">
                            <table class="admin-table features-links-results-table">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Slug</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var result in _linkSearchResults)
                                    {
                                        var r = result;
                                        var alreadyLinked = _editingLinks.Any(l => l.CollectionName == r.CollectionName && l.ItemSlug == r.Slug);
                                        <tr class="@(alreadyLinked ? "features-link-already-added" : "")">
                                            <td class="admin-cell-article" title="@r.Title">@r.Title</td>
                                            <td class="admin-cell-mono">@r.CollectionName/@r.Slug</td>
                                            <td>
                                                @if (!alreadyLinked)
                                                {
                                                    <button class="admin-link-btn" @onclick="() => AddLinkAsync(r, false)" disabled="@_saving">+ Link</button>
                                                    <button class="admin-link-btn" @onclick="() => AddLinkAsync(r, true)" disabled="@_saving">★ Thumbnail</button>
                                                }
                                                else
                                                {
                                                    <span class="admin-cell-mono" style="color:var(--color-text-secondary)">linked</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="admin-modal-footer">
                @if (_confirmingDelete)
                {
                    <span class="features-delete-confirm-text">Delete <strong>@_editing?.Slug</strong>? This cannot be undone.</span>
                    <button class="btn-danger" @onclick="ExecuteDeleteAsync" disabled="@_saving">Confirm Delete</button>
                    <button class="btn-secondary" @onclick="() => _confirmingDelete = false" disabled="@_saving">Cancel</button>
                }
                else
                {
                    <button class="btn-danger" @onclick="() => _confirmingDelete = true" disabled="@_saving">Delete</button>
                    <div class="admin-modal-footer-right">
                        <button class="btn-secondary" @onclick="CloseEditor" disabled="@_saving">Cancel</button>
                        <button class="btn" @onclick="SaveFeatureAsync" disabled="@_saving">
                            @(_saving ? "Saving…" : "Save")
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private static readonly string[] _allPlans = ["Free", "Student", "Pro", "Business", "Pro+", "Enterprise"];

    private bool _loading = true;
    private string? _error;
    private string? _message;
    private bool _messageIsError;
    private List<GhcFeature> _items = [];

    private bool _editorOpen;
    private GhcFeature? _editing;
    private string _editingDescription = string.Empty;
    private string? _editingReleaseDate;
    private HashSet<string> _editingPlans = [];
    private bool _editingGhesSupport;
    private List<GhcFeatureContentLink> _editingLinks = [];
    private bool _saving;
    private bool _confirmingDelete;

    // Content link sub-messages
    private string? _linkMessage;
    private bool _linkMessageIsError;

    // Content link search
    private string _linkSearchQuery = string.Empty;
    private string _linkSearchCollection = string.Empty;
    private bool _linkSearchLoading;
    private string? _linkSearchError;
    private List<ContentItemListItem> _linkSearchResults = [];

    private PersistingComponentStateSubscription _persistSubscription;

    protected override async Task OnInitializedAsync()
    {
        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistState);

        if (ApplicationState.TryTakeFromJson<List<GhcFeature>>("admin-copilot-features", out var persisted) && persisted != null)
        {
            _items = persisted;
            _loading = false;
            return;
        }

        await LoadFeaturesAsync();
    }

    private Task PersistState()
    {
        ApplicationState.PersistAsJson("admin-copilot-features", _items);
        return Task.CompletedTask;
    }

    private async Task LoadFeaturesAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var result = await Api.GetGhcFeaturesAsync();
            _items = (result ?? Enumerable.Empty<GhcFeature>())
                .OrderByDescending(i => i.ReleaseDate ?? 0)
                .ThenBy(i => i.Title)
                .ToList();
        }
        catch (HttpRequestException ex)
        {
            _error = $"Failed to load features: {ex.Message}";
            Logger.LogError(ex, "Failed to load ghc-features for admin page");
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenEditor(GhcFeature item)
    {
        _editing = item;
        _editingDescription = item.Description;
        _editingReleaseDate = item.ReleaseDate is long ts
            ? DateTimeOffset.FromUnixTimeSeconds(ts).ToOffset(TimeSpan.FromHours(1)).ToString("yyyy-MM-dd")
            : null;
        _editingPlans = [.. item.Plans];
        _editingGhesSupport = item.GhesSupport;
        _editingLinks = [.. item.ContentLinks];
        _linkSearchQuery = string.Empty;
        _linkSearchCollection = string.Empty;
        _linkSearchResults = [];
        _linkSearchError = null;
        _linkMessage = null;
        _confirmingDelete = false;
        _editorOpen = true;
        _message = null;
    }

    private void CloseEditor()
    {
        _editorOpen = false;
        _editing = null;
        _confirmingDelete = false;
    }

    private void TogglePlan(string plan)
    {
        if (_editingPlans.Contains(plan))
        {
            _editingPlans.Remove(plan);
        }
        else
        {
            _editingPlans.Add(plan);
        }
    }

    private long? ParseReleaseDate()
    {
        if (string.IsNullOrWhiteSpace(_editingReleaseDate))
        {
            return null;
        }

        if (DateTime.TryParseExact(_editingReleaseDate, "yyyy-MM-dd",
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None, out var dt))
        {
            return new DateTimeOffset(dt, TimeSpan.FromHours(1)).ToUnixTimeSeconds();
        }

        return null;
    }

    private async Task SaveFeatureAsync()
    {
        if (_editing is null)
        {
            return;
        }

        _saving = true;
        _message = null;

        try
        {
            var updated = _editing with
            {
                Description = _editingDescription.Trim(),
                ReleaseDate = ParseReleaseDate(),
                Plans = [.. _editingPlans],
                GhesSupport = _editingGhesSupport
            };

            await Api.UpsertGhcFeatureAsync(updated);

            _message = $"'{_editing.Slug}' updated successfully.";
            _messageIsError = false;
            CloseEditor();

            await LoadFeaturesAsync();
        }
        catch (HttpRequestException ex)
        {
            _message = $"Failed to save: {ex.Message}";
            _messageIsError = true;
            Logger.LogError(ex, "Failed to update feature {Slug}", _editing?.Slug);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ExecuteDeleteAsync()
    {
        if (_editing is null)
        {
            return;
        }

        _saving = true;

        try
        {
            var deleted = await Api.DeleteGhcFeatureAsync(_editing.Slug);
            _message = deleted
                ? $"'{_editing.Slug}' deleted successfully."
                : $"'{_editing.Slug}' was not found.";
            _messageIsError = !deleted;
            CloseEditor();
            await LoadFeaturesAsync();
        }
        catch (HttpRequestException ex)
        {
            _message = $"Failed to delete: {ex.Message}";
            _messageIsError = true;
            Logger.LogError(ex, "Failed to delete ghc-feature {Slug}", _editing?.Slug);
            _confirmingDelete = false;
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Content link management ───────────────────────────────────────────────

    private async Task SearchContentItemsAsync()
    {
        if (string.IsNullOrWhiteSpace(_linkSearchQuery))
        {
            return;
        }

        _linkSearchLoading = true;
        _linkSearchError = null;
        _linkSearchResults = [];

        try
        {
            var result = await Api.GetContentItemsAsync(
                page: 1,
                pageSize: 20,
                search: _linkSearchQuery.Trim(),
                collectionName: string.IsNullOrEmpty(_linkSearchCollection) ? null : _linkSearchCollection);
            _linkSearchResults = [.. (result.Items ?? [])];
        }
        catch (HttpRequestException ex)
        {
            _linkSearchError = $"Search failed: {ex.Message}";
            Logger.LogError(ex, "Failed to search content items for link addition");
        }
        finally
        {
            _linkSearchLoading = false;
        }
    }

    private async Task AddLinkAsync(ContentItemListItem item, bool asThumbnail)
    {
        if (_editing is null)
        {
            return;
        }

        _saving = true;
        _linkMessage = null;

        try
        {
            var nextSortOrder = _editingLinks.Count > 0 ? _editingLinks.Max(l => l.SortOrder) + 1 : 0;

            await Api.AddGhcFeatureContentLinkAsync(
                _editing.Slug,
                item.CollectionName,
                item.Slug,
                asThumbnail,
                nextSortOrder);

            await RefreshEditingFeatureAsync();
        }
        catch (HttpRequestException ex)
        {
            _linkMessage = $"Failed to add link: {ex.Message}";
            _linkMessageIsError = true;
            Logger.LogError(ex, "Failed to add content link to feature {Slug}", _editing?.Slug);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task RemoveLinkAsync(GhcFeatureContentLink link)
    {
        if (_editing is null)
        {
            return;
        }

        _saving = true;
        _linkMessage = null;

        try
        {
            await Api.RemoveGhcFeatureContentLinkAsync(_editing.Slug, link.CollectionName, link.ItemSlug);
            await RefreshEditingFeatureAsync();
        }
        catch (HttpRequestException ex)
        {
            _linkMessage = $"Failed to remove link: {ex.Message}";
            _linkMessageIsError = true;
            Logger.LogError(ex, "Failed to remove content link from feature {Slug}", _editing?.Slug);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SetThumbnailAsync(GhcFeatureContentLink link)
    {
        if (_editing is null)
        {
            return;
        }

        _saving = true;
        _linkMessage = null;

        try
        {
            await Api.SetGhcFeatureThumbnailAsync(_editing.Slug, link.CollectionName, link.ItemSlug);
            await RefreshEditingFeatureAsync();
        }
        catch (HttpRequestException ex)
        {
            _linkMessage = $"Failed to set thumbnail: {ex.Message}";
            _linkMessageIsError = true;
            Logger.LogError(ex, "Failed to set thumbnail for feature {Slug}", _editing?.Slug);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task RefreshEditingFeatureAsync()
    {
        var result = await Api.GetGhcFeaturesAsync();
        var refreshed = result?.FirstOrDefault(f => f.Slug == _editing!.Slug);
        if (refreshed is not null)
        {
            _editing = refreshed;
            _editingLinks = [.. refreshed.ContentLinks];

            var idx = _items.FindIndex(i => i.Slug == refreshed.Slug);
            if (idx >= 0)
            {
                _items[idx] = refreshed;
            }
        }
    }

    public void Dispose()
    {
        _persistSubscription.Dispose();
    }
}
