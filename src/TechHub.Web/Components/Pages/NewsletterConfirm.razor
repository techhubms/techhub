@page "/newsletter/confirm"
@using TechHub.Web.Services
@inject ITechHubApiClient Api
@implements IDisposable
@inherits PageComponentBase

@inject PersistentComponentState ApplicationState

<PageTitle>Newsletter Confirm — TechHub</PageTitle>

<main class="page-without-sidebar">
    <section>
        <h1 id="skiptohere" class="page-h1">Newsletter Subscription</h1>

        @if (_loading)
        {
            <p class="subscribe-intro">Confirming your subscription…</p>
        }
        else
        {
            <div class="subscribe-alert @(_success ? "subscribe-alert-success" : "subscribe-alert-error")">@_message</div>
        }
    </section>
</main>

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private bool _loading = true;
    private bool _success;
    private string _message = "Something went wrong while confirming your subscription.";
    private PersistingComponentStateSubscription? _persistSubscription;

    private const string StateKey = "newsletter-confirm-result";

    protected override async Task OnInitializedAsync()
    {
        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistState);

        if (ApplicationState.TryTakeFromJson<NewsletterConfirmResult>(StateKey, out var restored) && restored != null)
        {
            _message = restored.Message;
            _success = restored.Success;
            _loading = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
        {
            _message = "Invalid confirmation link.";
            _loading = false;
            return;
        }

        try
        {
            _message = await Api.ConfirmNewsletterAsync(Email, Token);
            _success = true;
        }
        catch (HttpRequestException)
        {
            _message = "Invalid or expired confirmation link.";
        }
        finally
        {
            _loading = false;
        }
    }

    private Task PersistState()
    {
        ApplicationState.PersistAsJson(StateKey, new NewsletterConfirmResult(_message, _success));
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _persistSubscription?.Dispose();
        GC.SuppressFinalize(this);
    }

    private sealed record NewsletterConfirmResult(string Message, bool Success);
}
