@page "/newsletter/unsubscribe"
@using TechHub.Web.Services
@inject ITechHubApiClient Api
@inherits PageComponentBase

<PageTitle>Newsletter Unsubscribe — TechHub</PageTitle>

<main class="page-without-sidebar">
    <section>
        <h1 id="skiptohere" class="page-h1">Newsletter Unsubscribe</h1>

        @if (_loading)
        {
            <p class="subscribe-intro">Processing your unsubscribe request…</p>
        }
        else
        {
            <div class="subscribe-alert @(_success ? "subscribe-alert-success" : "subscribe-alert-error")">@_message</div>
        }
    </section>
</main>

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private bool _loading = true;
    private bool _success;
    private string _message = "Something went wrong while unsubscribing.";
    private bool _handled;

    protected override async Task OnParametersSetAsync()
    {
        if (_handled)
        {
            return;
        }

        _handled = true;
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
        {
            _message = "Invalid unsubscribe link.";
            _loading = false;
            return;
        }

        try
        {
            await Api.UnsubscribeNewsletterAsync(Email, Token);
            _message = "You've been unsubscribed from the TechHub newsletter.";
            _success = true;
        }
        catch (HttpRequestException)
        {
            _message = "Invalid or expired unsubscribe link.";
        }
        finally
        {
            _loading = false;
        }
    }
}
