@using TechHub.Core.Models
@using TechHub.Web.Services

@if (!string.IsNullOrWhiteSpace(Item.RenderedHtml))
{
    <article id="@Id" class="article-body">
        <div class="content-detail-header">
            <h1 id="skiptohere" class="page-h1">@Item.Title</h1>

            <div class="article-metadata">
                <time datetime="@FormatDateIso(Item.DateEpoch)" title="@FormatDateFull(Item.DateEpoch)">@FormatDate(Item.DateEpoch)</time>@if (!string.IsNullOrWhiteSpace(Item.Author))
                {<span class="content-author"> by @Item.Author</span>}
            </div>
        </div>
        <SafeMarkup Html="@Item.RenderedHtml" />
    </article>
}

@code {
    [Parameter, EditorRequired]
    public TechHub.Core.Models.ContentItemDetail Item { get; set; } = null!;

    [Parameter]
    public string? Id { get; set; }

    private static string FormatDate(long epochSeconds) =>
        epochSeconds == 0 ? string.Empty : DateHelper.FormatDateRelative(epochSeconds);
    private static string FormatDateFull(long epochSeconds) => DateHelper.FormatDateFull(epochSeconds);
    private static string FormatDateIso(long epochSeconds) => DateHelper.FormatDateIso(epochSeconds);
}