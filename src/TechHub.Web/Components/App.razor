        src: "https://js.monitor.azure.com/scripts/b/ai.3.gbl.min.js",
        crossOrigin: "anonymous",
        cfg: {
            connectionString: "@appInsightsConnectionString",
            enableAutoRouteTracking: false  // We'll handle Blazor navigation manually
        },
        onInit: function(sdk) {
            // Suppress dependency failure noise from ad-blocker-blocked Google Analytics requests.
            // Ad blockers (browser extensions, DNS-level) block these requests, causing them to appear
            // as failed dependencies in Application Insights — masking real failures in the dashboard.
            sdk.addTelemetryInitializer(function(envelope) {
                if (envelope.baseType === 'RemoteDependencyData') {
                    var target = envelope.baseData && envelope.baseData.target;
                    if (target && (
                        target.indexOf('google-analytics.com') !== -1 ||
                        target.indexOf('googletagmanager.com') !== -1
                    )) {
                        return false;
                    }
                }
            });
        }
        });
        </script>
    }
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>

    @if (!isDevelopment && !string.IsNullOrEmpty(gaMeasurementId))
    {
        <!-- Google Analytics - Track Blazor enhanced navigation -->
        <script>
        (function() {
            // Guard against duplicate listener registration if this script ever re-runs
            if (window._gaEnhancedLoadRegistered) return;
            window._gaEnhancedLoadRegistered = true;

            function trackGAPageView() {
                if (typeof gtag === 'function') {
                    gtag('event', 'page_view', {
                        page_path: window.location.pathname,
                        page_location: window.location.href,
                        page_title: document.title
                    });
                }
            }

            if (window.Blazor) {
                Blazor.addEventListener('enhancedload', trackGAPageView);
            } else {
                const checkBlazor = setInterval(() => {
                    if (window.Blazor) {
                        clearInterval(checkBlazor);
                        Blazor.addEventListener('enhancedload', trackGAPageView);
                    }
                }, 100);
                setTimeout(() => clearInterval(checkBlazor), 5000);
            }
        })();
        </script>
    }

    @if (!isDevelopment && !string.IsNullOrEmpty(appInsightsConnectionString))
    {
        <!-- Application Insights - Track Blazor enhanced navigation -->
        <script>
        // Track Blazor enhanced navigation page views
        (function() {
            // Guard against duplicate listener registration if this script ever re-runs
            if (window._aiEnhancedLoadRegistered) return;
            window._aiEnhancedLoadRegistered = true;

            function trackPageView() {
                if (window.appInsights) {
                    appInsights.trackPageView({ uri: window.location.pathname });
                }
            }

            // For initial load, SDK handles it automatically
            // For Blazor enhanced navigation, track manually
            if (window.Blazor) {
                Blazor.addEventListener('enhancedload', trackPageView);
            } else {
                // Wait for Blazor to initialize
                const checkBlazor = setInterval(() => {
                    if (window.Blazor) {
                        clearInterval(checkBlazor);
                        Blazor.addEventListener('enhancedload', trackPageView);
                    }
                }, 100);
                setTimeout(() => clearInterval(checkBlazor), 5000);
            }
        })();
        </script>
    }

    <!-- Navigation Helpers - Back to Top and Back to Previous -->
    <!-- Uses @Assets for fingerprinted URL (cache busting). See Configuration/JsFiles.cs -->
    <script src="@Assets["js/nav-helpers.js"]" defer></script>

    <!-- Mobile Navigation - Scroll lock and keyboard handling for hamburger menu -->
    <!-- Uses @Assets for fingerprinted URL (cache busting). See Configuration/JsFiles.cs -->
    <script src="@Assets["js/mobile-nav.js"]" defer></script>

    <!-- Sidebar Toggle - Desktop sidebar collapse/expand with cookie persistence -->
    <!-- Uses @Assets for fingerprinted URL (cache busting). See Configuration/JsFiles.cs -->
    <script src="@Assets["js/sidebar-toggle.js"]" defer></script>

    <!-- Hero Banner - Collapse/expand with cookie persistence -->
    <!-- Uses @Assets for fingerprinted URL (cache busting). See Configuration/JsFiles.cs -->
    <script src="@Assets["js/hero-banner.js"]" defer></script>

    <!-- CDN Configuration - bridges C# version management to JavaScript -->
    <!-- CDN versions configured in Configuration/CdnLibraries.cs -->
    <script>
        // CDN Library Configuration - rendered from C# for single source of truth
        // See: Configuration/CdnLibraries.cs
        window.TechHubCDN = {
            highlightJs: {
                version: '@TechHub.Web.Configuration.CdnLibraries.HighlightJs.Version',
                cdnUrl: '@TechHub.Web.Configuration.CdnLibraries.HighlightJs.CdnUrl',
                coreIntegrity: '@TechHub.Web.Configuration.CdnLibraries.HighlightJs.CoreIntegrity',
                themeIntegrity: '@TechHub.Web.Configuration.CdnLibraries.HighlightJs.ThemeIntegrity',
                themeFile: '@TechHub.Web.Configuration.CdnLibraries.HighlightJs.ThemeFile',
                languages: @(new MarkupString(System.Text.Json.JsonSerializer.Serialize(TechHub.Web.Configuration.CdnLibraries.HighlightJs.Languages))),
                thirdPartyLanguages: {
                    terraform: '@TechHub.Web.Configuration.CdnLibraries.HighlightJs.ThirdPartyLanguages.TerraformCdnUrl'
                }
            },
            mermaid: {
                version: '@TechHub.Web.Configuration.CdnLibraries.Mermaid.Version',
                cdnUrl: '@TechHub.Web.Configuration.CdnLibraries.Mermaid.CdnUrl'
            }
        };
    </script>

    <!-- Page Script Initializers - loaded as ES module for lazy-loading support -->
    <!-- Individual Blazor components call initHighlighting/initMermaid/etc. from OnAfterRenderAsync -->
    <script type="module" src="@Assets["js/page-scripts.js"]"></script>
</body>

@code {
    /// <summary>
    /// CSS class(es) applied to the &lt;html&gt; element.
    /// Reads the 'sidebar-collapsed' cookie server-side during SSR so the collapsed
    /// state is rendered in the initial HTML — no FOUC, no inline script needed.
    /// </summary>
    private string HtmlClass =>
        HttpContextAccessor.HttpContext?.Request.Cookies["sidebar-collapsed"] == "true"
            ? "sidebar-collapsed"
            : string.Empty;
}

</html>