@using TechHub.Web.Services
@inject FaviconService FaviconService
@inject IConfiguration Configuration
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en" class="@HtmlClass">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0A0A19" />
    <base href="/" />

    <ImportMap />
    <HeadOutlet @rendermode="InteractiveServer" />

    <!-- Global CSS: @Assets produces fingerprinted URLs (content hash in filename) -->
    <!-- Fingerprinting ensures browsers automatically fetch new versions after deployments -->
    <!-- IMPORTANT: When adding CSS files, also update Configuration/CssFiles.cs -->
    <link rel="stylesheet" href="@Assets["css/design-tokens.css"]" />
    <link rel="stylesheet" href="@Assets["css/base.css"]" />
    <link rel="stylesheet" href="@Assets["css/buttons.css"]" />
    <link rel="stylesheet" href="@Assets["css/cards.css"]" />
    <link rel="stylesheet" href="@Assets["css/article.css"]" />
    <link rel="stylesheet" href="@Assets["css/sidebar.css"]" />
    <link rel="stylesheet" href="@Assets["css/page-container.css"]" />
    <link rel="stylesheet" href="@Assets["css/loading.css"]" />
    <link rel="stylesheet" href="@Assets["css/nav-helpers.css"]" />

    <!-- Scoped Component Styles -->
    <link rel="stylesheet" href="@Assets["TechHub.Web.styles.css"]" />

    <!-- Favicon embedded as data URI to eliminate HTTP requests during navigation -->
    <link id="favicon" rel="icon" type="image/x-icon" href="@FaviconService.DataUri" sizes="any" data-permanent />

    @{
        var appInsightsConnectionString = Environment.GetEnvironmentVariable("APPLICATIONINSIGHTS_CONNECTION_STRING");
        var isDevelopment = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development";
        var gaMeasurementId = Configuration["GoogleAnalytics:MeasurementId"];
    }

    @if (isDevelopment)
    {
        <!-- E2E test lifecycle counter — provides a single monotonic counter that
             all JS lifecycle hooks increment via __e2eSignal(label). Tests capture
             the counter before an action and wait for it to change, replacing 8+
             independent window.__* flags with one universal wait pattern.
             Gated to Development only — zero production overhead. -->
        <script>
            if (!window.__e2e) {
                window.__e2e = { counter: 0, label: 'init', history: [] };
                window.__e2eSignal = function(label) {
                    if (!window.__e2e) return;
                    window.__e2e.counter++;
                    window.__e2e.label = label;
                    window.__e2e.history.push({ counter: window.__e2e.counter, label: label });
                    if (window.__e2e.history.length > 20) window.__e2e.history.shift();
                };
                window.addEventListener('scrollend', function() { window.__e2eSignal('scroll-end'); });
            }
        </script>
    }

    @if (!isDevelopment && !string.IsNullOrEmpty(gaMeasurementId))
    {
        <!-- Google Analytics 4 - async loading, no render blocking -->
        <script async src="https://www.googletagmanager.com/gtag/js?id=@gaMeasurementId"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '@gaMeasurementId', {
                'anonymize_ip': true,
                'allow_google_signals': false,
                'allow_ad_personalization_signals': false,
                'send_page_view': false
            });
        </script>
    }

    @if (!isDevelopment && !string.IsNullOrEmpty(appInsightsConnectionString))
    {
        <!-- Application Insights JavaScript SDK for client-side telemetry -->
        <script type="text/javascript">
